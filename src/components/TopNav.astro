---
import LogoMark from './LogoMark.astro';
import { site, nav } from '../config/site';
---

<nav class="topnav">
  <div class="topnav-inner">
    <a href="/" class="topnav-brand" aria-label={`${site.name} — accueil`}>
      <LogoMark size={40} />
      <div class="topnav-brand-text">
        <span class="topnav-wordmark">{site.name}</span>
        <span class="topnav-tag">{site.tagline}</span>
      </div>
    </a>

    <ul class="topnav-links">
      {nav.map((item) => (
        <li><a href={item.href}>{item.label}</a></li>
      ))}
    </ul>

    <div class="topnav-cta">
      <a href={site.phone.href} class="topnav-phone">{site.phone.display}</a>
      <a href="#devis" class="btn btn-primary topnav-quote">Demande de devis</a>
    </div>

    <button class="topnav-burger" aria-label="Menu" aria-controls="mobile-menu" aria-expanded="false" id="burger">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="topnav-mobile" id="mobile-menu" hidden>
    <ul>
      {nav.map((item) => (
        <li><a href={item.href}>{item.label}</a></li>
      ))}
      <li><a href={site.phone.href} class="mobile-phone mono">{site.phone.display}</a></li>
      <li><a href="#devis" class="btn btn-primary mobile-quote">Demande de devis</a></li>
    </ul>
  </div>
</nav>

<style>
  .topnav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: box-shadow var(--dur-slow) var(--ease-standard);
  }
  .topnav.scrolled { box-shadow: var(--shadow-md); }

  .topnav-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 14px var(--pad-x-desktop);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .topnav-brand {
    display: flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
  }
  .topnav-brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }
  .topnav-wordmark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 15px;
    letter-spacing: var(--tr-display);
    color: var(--color-text);
  }
  .topnav-tag {
    font-size: 10px;
    color: var(--color-text-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
    margin-top: 2px;
  }

  .topnav-links {
    display: flex;
    align-items: center;
    gap: 28px;
  }
  .topnav-links a {
    font-size: 13px;
    color: var(--color-text);
    font-weight: 500;
    text-decoration: none;
    padding: 4px 0;
    border-bottom: 2px solid transparent;
    transition: border-color var(--dur-fast) var(--ease-standard), color var(--dur-fast) var(--ease-standard);
  }
  .topnav-links a:hover { color: var(--color-primary); border-color: var(--color-primary); }

  .topnav-cta { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }
  .topnav-phone {
    padding: 10px 16px;
    border-radius: var(--radius-md);
    background: transparent;
    color: var(--color-primary);
    border: 1px solid var(--color-primary);
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    font-family: var(--font-mono);
    transition: background-color var(--dur-base) var(--ease-standard), color var(--dur-base) var(--ease-standard);
  }
  .topnav-phone:hover { background: var(--color-primary-bg); }
  .topnav-quote {
    padding: 10px 16px;
    font-size: 13px;
    border-radius: var(--radius-md);
  }

  /* Burger (mobile) */
  .topnav-burger {
    display: none;
    width: 40px;
    height: 40px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: transparent;
    padding: 0;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 4px;
  }
  .topnav-burger span {
    width: 18px;
    height: 2px;
    background: var(--color-text);
    border-radius: 1px;
  }

  .topnav-mobile { display: none; }
  .topnav-mobile ul {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 8px var(--pad-x-mobile) 20px;
    border-top: 1px solid var(--color-border);
  }
  .topnav-mobile a {
    display: block;
    padding: 12px 4px;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
  }
  .mobile-phone { color: var(--color-primary) !important; }
  .mobile-quote { justify-content: center; margin-top: 6px; }

  @media (max-width: 1023px) {
    .topnav-inner { padding: 12px var(--pad-x-tablet); gap: 16px; }
    .topnav-wordmark { font-size: 14px; }
    .topnav-links { gap: 18px; }
  }

  @media (max-width: 900px) {
    .topnav-links { display: none; }
  }

  @media (max-width: 767px) {
    .topnav-inner { padding: 12px var(--pad-x-mobile); }
    .topnav-cta { display: none; }
    .topnav-burger { display: flex; }
    .topnav-tag { display: none; }
    .topnav-mobile { display: block; }
    .topnav-mobile[hidden] { display: none; }
  }
</style>

<script>
  // Burger menu toggle
  const burger = document.getElementById('burger');
  const menu = document.getElementById('mobile-menu');
  burger?.addEventListener('click', () => {
    const isOpen = !menu?.hidden;
    if (menu) menu.hidden = isOpen;
    burger.setAttribute('aria-expanded', String(!isOpen));
  });

  // Scrolled state → subtle shadow
  const nav = document.querySelector('.topnav');
  const onScroll = () => nav?.classList.toggle('scrolled', window.scrollY > 8);
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
