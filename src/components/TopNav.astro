---
import LogoMark from './LogoMark.astro';
import { site, nav } from '../config/site';
---

<nav class="topnav">
  <div class="topnav-inner">
    <a href="/" class="topnav-brand" aria-label={`${site.name} · accueil`}>
      <LogoMark size={32} />
    </a>

    <a href="/recrutement" class="topnav-recruit" aria-label="Montpellier Dépannage recrute">
      <span class="topnav-recruit-dot" aria-hidden="true"></span>
      MDP recrute
    </a>

    <ul class="topnav-links">
      {nav.map((item) => (
        <li><a href={item.href}>{item.label}</a></li>
      ))}
    </ul>

    <div class="topnav-cta">
      <a href="/#assistance" class="topnav-assist">Vous êtes en panne&nbsp;?</a>
      <a href={site.phone.href} class="btn btn-primary topnav-phone-cta mono">
        <span aria-hidden="true">☎</span> {site.phone.display}
      </a>
    </div>

    <button class="topnav-burger" aria-label="Menu" aria-controls="mobile-menu" aria-expanded="false" id="burger">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="topnav-mobile" id="mobile-menu" hidden>
    <ul>
      {nav.map((item) => (
        <li><a href={item.href}>{item.label}</a></li>
      ))}
      <li><a href="/recrutement" class="mobile-recruit"><span class="topnav-recruit-dot" aria-hidden="true"></span> MDP recrute</a></li>
      <li><a href="/#assistance" class="mobile-assist">Vous êtes en panne&nbsp;?</a></li>
      <li><a href={site.phone.href} class="btn btn-primary mobile-phone-cta mono">☎ {site.phone.display}</a></li>
    </ul>
  </div>
</nav>

<style>
  .topnav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: box-shadow var(--dur-slow) var(--ease-standard);
  }
  .topnav.scrolled { box-shadow: var(--shadow-md); }

  .topnav-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 14px var(--pad-x-desktop);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .topnav-brand {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
  }

  /* Pill "MDP recrute" — placée à gauche du nav, signal jaune */
  .topnav-recruit {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 14px;
    border-radius: var(--radius-pill);
    background: var(--md-signal-300);
    color: var(--md-brand-black);
    font-size: 12px;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 0.03em;
    border: 1px solid rgba(26,25,15,0.15);
    box-shadow: 0 2px 8px rgba(228,225,60,0.5);
    transition: transform var(--dur-base) var(--ease-standard),
                box-shadow var(--dur-base) var(--ease-standard);
    flex-shrink: 0;
  }
  .topnav-recruit:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(228,225,60,0.65);
  }
  .topnav-recruit-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #2C6126;
    box-shadow: 0 0 0 3px rgba(44,97,38,0.18);
    animation: recruit-pulse 1.8s ease-in-out infinite;
  }
  @keyframes recruit-pulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(44,97,38,0.18); }
    50%      { box-shadow: 0 0 0 6px rgba(44,97,38,0.05); }
  }

  .topnav-links {
    display: flex;
    align-items: center;
    gap: 28px;
  }
  .topnav-links a {
    font-size: 14px;
    color: var(--color-text);
    font-weight: 500;
    text-decoration: none;
    padding: 4px 0;
    border-bottom: 2px solid transparent;
    transition: border-color var(--dur-fast) var(--ease-standard), color var(--dur-fast) var(--ease-standard);
  }
  .topnav-links a:hover { color: var(--color-primary); border-color: var(--color-primary); }

  .topnav-cta { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }
  .topnav-assist {
    padding: 10px 16px;
    border-radius: var(--radius-md);
    background: transparent;
    color: var(--color-text);
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    border: 1px solid var(--color-border);
    transition: background-color var(--dur-base) var(--ease-standard), border-color var(--dur-base) var(--ease-standard), color var(--dur-base) var(--ease-standard);
  }
  .topnav-assist:hover {
    background: var(--color-primary-bg);
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
  .topnav-phone-cta {
    padding: 10px 16px;
    font-size: 14px;
    border-radius: var(--radius-md);
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  /* Burger (mobile) */
  .topnav-burger {
    display: none;
    width: 40px;
    height: 40px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: transparent;
    padding: 0;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 4px;
  }
  .topnav-burger span {
    width: 18px;
    height: 2px;
    background: var(--color-text);
    border-radius: 1px;
  }

  .topnav-mobile { display: none; }
  .topnav-mobile ul {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 8px var(--pad-x-mobile) 20px;
    border-top: 1px solid var(--color-border);
  }
  .topnav-mobile a {
    display: block;
    padding: 12px 4px;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
  }
  .mobile-assist { color: var(--color-text) !important; }
  .mobile-recruit {
    display: flex !important;
    align-items: center;
    gap: 8px;
    background: var(--md-signal-300);
    color: var(--md-brand-black) !important;
    border-radius: var(--radius-pill);
    padding: 12px 16px !important;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .mobile-phone-cta { justify-content: center; margin-top: 6px; display: flex; align-items: center; gap: 8px; }

  @media (max-width: 1023px) {
    .topnav-inner { padding: 12px var(--pad-x-tablet); gap: 16px; }
    .topnav-links { gap: 18px; }
  }

  @media (max-width: 900px) {
    .topnav-links { display: none; }
  }

  @media (max-width: 767px) {
    .topnav-inner { padding: 12px var(--pad-x-mobile); }
    .topnav-cta { display: none; }
    .topnav-recruit { display: none; } /* visible uniquement dans le menu burger */
    .topnav-burger { display: flex; }
    .topnav-mobile { display: block; }
    .topnav-mobile[hidden] { display: none; }
  }
</style>

<script>
  // Burger menu toggle
  const burger = document.getElementById('burger');
  const menu = document.getElementById('mobile-menu');
  burger?.addEventListener('click', () => {
    const isOpen = !menu?.hidden;
    if (menu) menu.hidden = isOpen;
    burger.setAttribute('aria-expanded', String(!isOpen));
  });

  // Scrolled state → subtle shadow
  const nav = document.querySelector('.topnav');
  const onScroll = () => nav?.classList.toggle('scrolled', window.scrollY > 8);
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
