---
import { photos } from '../../config/site';

const news = [
  { date: '25 / 02 / 2022', tag: 'Intervention', title: "Accident de poids lourd sur l'autoroute A9", img: photos.accidentPL },
  { date: '27 / 08 / 2021', tag: 'Équipement', title: 'Borne de recharge pour véhicules électriques', img: photos.bornesEV },
  { date: '12 / 04 / 2021', tag: 'Intervention', title: 'Accident et relevage PL sur A9', img: photos.plateauVL },
];
---

<section class="news" id="news">
  <div class="news-inner">
    <header class="news-head">
      <div>
        <div class="news-overline">Dernières actualités</div>
        <h2 class="news-title">Interventions et vie de l'entreprise</h2>
      </div>
      <a href="#" class="news-all">Toutes les actualités →</a>
    </header>

    <div class="news-grid">
      {news.map((n) => (
        <article class="news-card">
          <div class="news-card-img" style={`--news-img: url('${n.img}');`}></div>
          <div class="news-card-body">
            <div class="news-card-meta">
              <span class="news-card-date mono">{n.date}</span>
              <span class="news-card-sep" aria-hidden="true"></span>
              <span class="news-card-tag">{n.tag}</span>
            </div>
            <h3 class="news-card-title">{n.title}</h3>
            <a href="#" class="news-card-link">Lire la suite →</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .news {
    padding: 72px var(--pad-x-desktop) 80px;
    background: var(--color-bg-subtle);
  }
  .news-inner { max-width: var(--container-max); margin: 0 auto; }

  .news-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 32px;
    gap: 20px;
    flex-wrap: wrap;
  }
  .news-overline {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 10px;
  }
  .news-title {
    font-family: var(--font-display);
    font-size: 32px;
    margin: 0;
    color: var(--color-text);
    letter-spacing: var(--tr-display);
    font-weight: 700;
  }
  .news-all {
    font-size: 13px;
    color: var(--color-primary);
    font-weight: 700;
    text-decoration: none;
  }
  .news-all:hover { text-decoration: underline; }

  .news-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .news-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform var(--dur-base) var(--ease-standard), box-shadow var(--dur-base) var(--ease-standard);
  }
  .news-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  .news-card-img {
    height: 160px;
    background-image: var(--news-img);
    background-size: cover;
    background-position: center;
  }
  .news-card-body {
    padding: 18px 20px 20px;
  }
  .news-card-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .news-card-sep {
    width: 2px;
    height: 2px;
    background: var(--color-text-muted);
    border-radius: 50%;
  }
  .news-card-tag { color: var(--color-primary); }
  .news-card-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 10px;
    line-height: 1.35;
  }
  .news-card-link {
    font-size: 12px;
    color: var(--color-primary);
    font-weight: 700;
    text-decoration: none;
  }
  .news-card-link:hover { text-decoration: underline; }

  @media (max-width: 1023px) {
    .news { padding: 64px var(--pad-x-tablet) 72px; }
    .news-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 639px) {
    .news { padding: 48px var(--pad-x-mobile) 56px; }
    .news-grid { grid-template-columns: 1fr; }
    .news-title { font-size: 26px; }
  }
</style>
