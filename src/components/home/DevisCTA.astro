---
import { site } from '../../config/site';

const steps = [
  ['1', 'Type de véhicule', 'Voiture, PL, véhicule de luxe'],
  ['2', 'Lieu & destination', 'Adresse départ & arrivée'],
  ['3', 'Urgence', 'Immédiat ou planifié'],
];
---

<section class="devis" id="devis">
  <div class="devis-panel">
    <div class="devis-bg-blob" aria-hidden="true"></div>

    <div class="devis-grid">
      <div class="devis-copy">
        <div class="devis-overline">Obtenez votre devis</div>
        <h2 class="devis-title">Un besoin de remorquage&nbsp;? Répondez en 3 étapes.</h2>
        <p class="devis-lead">
          Type de véhicule, lieu d'enlèvement, destination. Devis détaillé sous 15 minutes
          aux heures ouvrées, ou appelez directement notre standard.
        </p>
        <div class="devis-cta">
          <a href="#" class="btn btn-accent devis-cta-primary">Commencer le devis →</a>
          <a href={site.phone.href} class="btn btn-ghost-dark devis-cta-phone mono">☎ {site.phone.display}</a>
        </div>
      </div>

      <ul class="devis-steps">
        {steps.map(([n, title, desc]) => (
          <li class="devis-step">
            <div class="devis-step-num">{n}</div>
            <div>
              <div class="devis-step-title">{title}</div>
              <div class="devis-step-desc">{desc}</div>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .devis {
    padding: 80px var(--pad-x-desktop);
    background: var(--color-bg);
  }
  .devis-panel {
    max-width: 1000px;
    margin: 0 auto;
    background: var(--color-primary);
    border-radius: var(--radius-2xl);
    padding: 56px;
    color: #fff;
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }
  .devis-bg-blob {
    position: absolute;
    right: -60px;
    top: -60px;
    width: 240px;
    height: 240px;
    border-radius: 50%;
    background: var(--md-brand-yellow);
    opacity: 0.15;
    pointer-events: none;
  }
  .devis-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .devis-overline {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--md-brand-yellow);
    margin-bottom: 10px;
  }
  .devis-title {
    font-family: var(--font-display);
    font-size: 36px;
    margin: 0 0 18px;
    letter-spacing: var(--tr-display);
    line-height: 1.1;
    font-weight: 700;
  }
  .devis-lead {
    font-size: 15px;
    line-height: 1.65;
    opacity: 0.88;
    margin: 0 0 28px;
    max-width: 440px;
  }
  .devis-cta {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .devis-cta-primary { padding: 14px 22px; font-size: 14px; }
  .devis-cta-phone { padding: 14px 22px; font-size: 14px; }

  .devis-steps {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .devis-step {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: var(--radius-lg);
    padding: 14px 16px;
    display: flex;
    gap: 14px;
    align-items: center;
    transition: background-color var(--dur-base) var(--ease-standard);
  }
  .devis-step:hover { background: rgba(255,255,255,0.12); }
  .devis-step-num {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--md-brand-yellow);
    color: var(--md-brand-black);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 14px;
    flex-shrink: 0;
  }
  .devis-step-title { font-size: 13px; font-weight: 700; }
  .devis-step-desc { font-size: 12px; opacity: 0.75; margin-top: 2px; }

  @media (max-width: 1023px) {
    .devis { padding: 72px var(--pad-x-tablet); }
    .devis-panel { padding: 44px 32px; }
    .devis-grid { grid-template-columns: 1fr; gap: 32px; }
    .devis-title { font-size: 30px; }
  }
  @media (max-width: 639px) {
    .devis { padding: 56px var(--pad-x-mobile); }
    .devis-panel { padding: 36px 24px; border-radius: var(--radius-xl); }
    .devis-title { font-size: 26px; }
    .devis-cta-primary, .devis-cta-phone { flex: 1; justify-content: center; }
  }
</style>
