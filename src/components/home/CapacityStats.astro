---
import { photos } from '../../config/site';

const kpis = [
  {
    value: 50000,
    prefix: '+',
    suffix: '',
    label: 'Interventions / an',
    kicker: '200 missions par jour, 300 jours par an',
  },
  {
    value: 45,
    prefix: '< ',
    suffix: ' min',
    label: 'Temps d’intervention',
    kicker: 'Sur la zone Montpellier & A9',
  },
  {
    value: 98,
    prefix: '',
    suffix: ' %',
    label: 'Satisfaction client',
    kicker: 'Enquête NF Service · 2024',
  },
  {
    value: 40,
    prefix: '',
    suffix: '',
    label: 'Dépanneurs certifiés',
    kicker: 'Formations PL, autoroute, GPL',
  },
];

// Format SSR pour que la valeur cible apparaisse dans le HTML statique
// (bon pour le SEO et les visiteurs sans JS). L'animation au scroll
// remettra le compteur à 0 puis l'animera vers la cible une fois en vue.
const fmtTarget = (n: number) =>
  n >= 1000 ? n.toLocaleString('fr-FR') : String(n);
---

<section class="cap" id="capacite" aria-labelledby="cap-title">
  <div class="cap-inner">
    <header class="cap-head">
      <div class="cap-overline">Notre capacité</div>
      <h2 class="cap-title" id="cap-title">
        Une flotte, une équipe,<br />
        <span class="cap-title-accent">des engagements qui tiennent.</span>
      </h2>
      <p class="cap-lead">
        Une entreprise familiale depuis 1956, 8&nbsp;agences dans l’Hérault et le Gard, une présence permanente sur l’A9.
        Voici nos engagements quotidiens envers vous.
      </p>
    </header>

    <!-- KPIs -->
    <ul class="cap-kpis">
      {kpis.map((k) => (
        <li class="cap-kpi">
          <div class="cap-kpi-value">
            <span class="cap-kpi-prefix">{k.prefix}</span><span
              data-counter
              data-target={k.value}
            >{fmtTarget(k.value)}</span><span class="cap-kpi-suffix">{k.suffix}</span>
          </div>
          <div class="cap-kpi-label">{k.label}</div>
          <div class="cap-kpi-kicker">{k.kicker}</div>
        </li>
      ))}
    </ul>

    <!-- Photo flotte -->
    <aside class="cap-photo" aria-hidden="true">
      <div class="cap-photo-img" style={`background-image: url('${photos.flotteCamions}');`}></div>
      <div class="cap-photo-overlay">
        <div class="cap-photo-pill mono">8 agences · 40 dépanneurs</div>
        <div class="cap-photo-stats">
          <div>
            <div class="cap-photo-stat-value">40</div>
            <div class="cap-photo-stat-label">Plateaux</div>
          </div>
          <div>
            <div class="cap-photo-stat-value">4×4</div>
            <div class="cap-photo-stat-label">Tout terrain</div>
          </div>
          <div>
            <div class="cap-photo-stat-value">24/7</div>
            <div class="cap-photo-stat-label">Astreinte</div>
          </div>
        </div>
      </div>
    </aside>
  </div>
</section>

<script>
  // Compteurs animés au scroll.
  // Le HTML statique contient déjà les valeurs cibles formatées
  // (cf. CapacityStats.astro / fmtTarget). Le JS, optionnel, anime
  // de 0 vers la cible quand l'élément entre dans le viewport APRÈS scroll.
  // Si l'utilisateur n'a pas scrollé (élément déjà visible au chargement),
  // on n'anime pas — la valeur SSR reste affichée, pas de flash "0".
  const counters = document.querySelectorAll<HTMLElement>('[data-counter]');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (counters.length && 'IntersectionObserver' in window && !prefersReducedMotion) {
    let hasScrolled = window.scrollY > 0;
    window.addEventListener(
      'scroll',
      () => { hasScrolled = true; },
      { once: true, passive: true },
    );
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          io.unobserve(el);
          // Élément visible avant tout scroll : on garde la valeur SSR.
          if (!hasScrolled) return;
          const target = parseFloat(el.dataset.target || '0');
          const duration = 1400;
          const start = performance.now();
          const fmt = (n: number) =>
            target >= 1000
              ? Math.round(n).toLocaleString('fr-FR')
              : Math.round(n).toString();
          const tick = (now: number) => {
            const t = Math.min(1, (now - start) / duration);
            const eased = 1 - Math.pow(1 - t, 3);
            el.textContent = fmt(target * eased);
            if (t < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        });
      },
      { threshold: 0.4 },
    );
    counters.forEach((c) => io.observe(c));
  }
</script>

<style>
  .cap {
    padding: 96px var(--pad-x-desktop);
    background: var(--color-bg-subtle);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .cap-inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }

  /* ---------- Head ---------- */
  .cap-head {
    max-width: 720px;
    margin-bottom: 56px;
  }
  .cap-overline {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    background: var(--color-primary-bg);
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    margin-bottom: 18px;
  }
  .cap-title {
    font-family: var(--font-display);
    font-size: 44px;
    line-height: 1.08;
    letter-spacing: var(--tr-display);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 18px;
  }
  .cap-title-accent { color: var(--color-primary); }
  .cap-lead {
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ---------- KPIs ---------- */
  .cap-kpis {
    list-style: none;
    margin: 0 0 64px;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .cap-kpi {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 26px 24px;
    box-shadow: var(--shadow-xs);
    position: relative;
    overflow: hidden;
    transition: transform var(--dur-base) var(--ease-standard),
                box-shadow var(--dur-base) var(--ease-standard);
  }
  .cap-kpi::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, var(--color-primary) 0%, var(--md-signal-300) 100%);
    opacity: 0.85;
  }
  .cap-kpi:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  .cap-kpi-value {
    font-family: var(--font-display);
    font-size: 44px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
    line-height: 1;
    font-variant-numeric: tabular-nums;
    display: flex;
    align-items: baseline;
    gap: 1px;
  }
  .cap-kpi-prefix,
  .cap-kpi-suffix {
    font-size: 0.7em;
    color: var(--color-primary);
    font-weight: 700;
  }
  .cap-kpi-label {
    margin-top: 10px;
    font-size: 14px;
    font-weight: 700;
    color: var(--color-text);
  }
  .cap-kpi-kicker {
    margin-top: 4px;
    font-size: 11px;
    color: var(--color-text-muted);
    line-height: 1.45;
  }

  /* ---------- Photo ---------- */
  .cap-photo {
    position: relative;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    isolation: isolate;
    min-height: 280px;
  }
  .cap-photo-img {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transform: scale(1.02);
    transition: transform 800ms var(--ease-out);
  }
  .cap-photo:hover .cap-photo-img { transform: scale(1.06); }
  .cap-photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(26,25,15,0) 30%, rgba(26,25,15,0.85) 100%);
    padding: 28px 32px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    color: #fff;
  }
  .cap-photo-pill {
    align-self: flex-start;
    background: var(--md-signal-300);
    color: var(--md-brand-black);
    padding: 8px 14px;
    border-radius: var(--radius-pill);
    font-size: 11px;
    font-family: var(--font-mono);
    font-weight: 700;
    letter-spacing: 0.08em;
  }
  .cap-photo-stats {
    display: grid;
    grid-template-columns: repeat(3, max-content);
    gap: 40px;
  }
  .cap-photo-stat-value {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    color: var(--md-signal-300);
    line-height: 1;
  }
  .cap-photo-stat-label {
    font-size: 11px;
    color: rgba(255,255,255,0.78);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 6px;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 1023px) {
    .cap { padding: 80px var(--pad-x-tablet); }
    .cap-title { font-size: 36px; }
    .cap-kpis { grid-template-columns: repeat(2, 1fr); }
    .cap-photo { min-height: 240px; }
  }
  @media (max-width: 639px) {
    .cap { padding: 64px var(--pad-x-mobile); }
    .cap-title { font-size: 28px; }
    .cap-kpi-value { font-size: 36px; }
    .cap-kpi { padding: 22px 20px; }
    .cap-photo-overlay { padding: 20px; }
    .cap-photo-stats { gap: 24px; }
    .cap-photo-stat-value { font-size: 22px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cap-photo-img { transition: none; }
  }
</style>
