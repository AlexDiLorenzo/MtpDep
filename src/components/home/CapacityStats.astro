---
import { photos } from '../../config/site';

const kpis = [
  {
    value: 12000,
    suffix: '+',
    label: 'Interventions / an',
    kicker: 'Sur l’ensemble du réseau Hérault',
  },
  {
    value: 28,
    suffix: ' min',
    label: 'Temps moyen d’arrivée',
    kicker: 'Sur la zone Montpellier & A9',
  },
  {
    value: 98,
    suffix: ' %',
    label: 'Satisfaction client',
    kicker: 'Enquête NF Service · 2024',
  },
  {
    value: 16,
    suffix: '',
    label: 'Dépanneurs certifiés',
    kicker: 'Formations PL, autoroute, GPL',
  },
];

// Graphique : évolution interventions par mois (illustratif)
const months = ['Jan', 'Fév', 'Mar', 'Avr', 'Mai', 'Jun', 'Jul', 'Aoû', 'Sep', 'Oct', 'Nov', 'Déc'];
const values = [820, 760, 880, 940, 1020, 1180, 1340, 1290, 1080, 1010, 920, 980];
const max = Math.max(...values);
const chartW = 720;
const chartH = 260;
const padL = 36;
const padR = 16;
const padT = 24;
const padB = 36;
const innerW = chartW - padL - padR;
const innerH = chartH - padT - padB;
const stepX = innerW / (values.length - 1);
const points = values.map((v, i) => {
  const x = padL + i * stepX;
  const y = padT + innerH - (v / max) * innerH;
  return [x, y] as const;
});
const pathD = points.map(([x, y], i) => `${i === 0 ? 'M' : 'L'} ${x.toFixed(1)} ${y.toFixed(1)}`).join(' ');
const areaD = `${pathD} L ${points[points.length - 1][0].toFixed(1)} ${(padT + innerH).toFixed(1)} L ${points[0][0].toFixed(1)} ${(padT + innerH).toFixed(1)} Z`;
---

<section class="cap" id="capacite" aria-labelledby="cap-title">
  <div class="cap-inner">
    <header class="cap-head">
      <div class="cap-overline">Notre capacité</div>
      <h2 class="cap-title" id="cap-title">
        Une flotte, une équipe,<br />
        <span class="cap-title-accent">des chiffres qui tiennent.</span>
      </h2>
      <p class="cap-lead">
        68&nbsp;ans d’expérience, deux sites opérationnels, une présence
        permanente sur l’A9. Voici en quelques chiffres ce que ça donne
        au quotidien.
      </p>
    </header>

    <!-- KPIs -->
    <ul class="cap-kpis">
      {kpis.map((k) => (
        <li class="cap-kpi">
          <div
            class="cap-kpi-value"
            data-counter
            data-target={k.value}
            data-suffix={k.suffix}
          >
            0{k.suffix}
          </div>
          <div class="cap-kpi-label">{k.label}</div>
          <div class="cap-kpi-kicker">{k.kicker}</div>
        </li>
      ))}
    </ul>

    <!-- Bloc graphique + photo -->
    <div class="cap-bottom">
      <figure class="cap-chart" aria-label="Volume d'interventions par mois en 2024">
        <figcaption class="cap-chart-head">
          <div>
            <div class="cap-chart-overline">Volume mensuel · 2024</div>
            <div class="cap-chart-title">Interventions par mois</div>
          </div>
          <div class="cap-chart-legend">
            <span class="cap-chart-legend-dot" aria-hidden="true"></span>
            Interventions
          </div>
        </figcaption>

        <svg
          class="cap-chart-svg"
          viewBox={`0 0 ${chartW} ${chartH}`}
          preserveAspectRatio="none"
          role="img"
          aria-hidden="true"
        >
          <defs>
            <linearGradient id="capArea" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#2C6126" stop-opacity="0.35" />
              <stop offset="100%" stop-color="#2C6126" stop-opacity="0" />
            </linearGradient>
            <linearGradient id="capLine" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="#2C6126" />
              <stop offset="100%" stop-color="#E4E13C" />
            </linearGradient>
          </defs>

          {/* Grille horizontale */}
          {[0, 0.25, 0.5, 0.75, 1].map((t) => {
            const y = padT + innerH * t;
            return (
              <line
                x1={padL}
                x2={chartW - padR}
                y1={y}
                y2={y}
                stroke="#D3D1C7"
                stroke-width="0.6"
                stroke-dasharray={t === 1 ? '0' : '3 4'}
              />
            );
          })}

          {/* Aire */}
          <path d={areaD} fill="url(#capArea)" class="cap-chart-area" />

          {/* Ligne */}
          <path
            d={pathD}
            fill="none"
            stroke="url(#capLine)"
            stroke-width="2.4"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="cap-chart-line"
          />

          {/* Points */}
          {points.map(([x, y], i) => (
            <g class="cap-chart-point" style={`--i:${i}`}>
              <circle cx={x} cy={y} r="4" fill="#fff" stroke="#2C6126" stroke-width="2" />
            </g>
          ))}

          {/* Labels mois */}
          {months.map((m, i) => (
            <text
              x={padL + i * stepX}
              y={chartH - 10}
              text-anchor="middle"
              font-family="'DM Sans', sans-serif"
              font-size="10"
              font-weight="600"
              fill="#888780"
            >{m}</text>
          ))}
        </svg>

        <div class="cap-chart-foot">
          <div class="cap-chart-trend">
            <span class="cap-chart-trend-arrow" aria-hidden="true">↗</span>
            +18&nbsp;% vs 2023
          </div>
          <div class="cap-chart-meta">Pic en juillet&nbsp;: 1&nbsp;340 interventions</div>
        </div>
      </figure>

      <aside class="cap-photo" aria-hidden="true">
        <div class="cap-photo-img" style={`background-image: url('${photos.flotteDepot}');`}></div>
        <div class="cap-photo-overlay">
          <div class="cap-photo-pill mono">2 sites · 16 dépanneurs</div>
          <div class="cap-photo-stats">
            <div>
              <div class="cap-photo-stat-value">10+</div>
              <div class="cap-photo-stat-label">Plateaux</div>
            </div>
            <div>
              <div class="cap-photo-stat-value">4×4</div>
              <div class="cap-photo-stat-label">Tout terrain</div>
            </div>
            <div>
              <div class="cap-photo-stat-value">24/7</div>
              <div class="cap-photo-stat-label">Astreinte</div>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<script>
  // Compteurs animés au scroll
  const counters = document.querySelectorAll<HTMLElement>('[data-counter]');
  if ('IntersectionObserver' in window && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          const target = parseFloat(el.dataset.target || '0');
          const suffix = el.dataset.suffix || '';
          const duration = 1400;
          const start = performance.now();
          const fmt = (n: number) => {
            if (target >= 1000) return Math.round(n).toLocaleString('fr-FR');
            return Math.round(n).toString();
          };
          const tick = (now: number) => {
            const t = Math.min(1, (now - start) / duration);
            const eased = 1 - Math.pow(1 - t, 3);
            el.textContent = fmt(target * eased) + suffix;
            if (t < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
          io.unobserve(el);
        });
      },
      { threshold: 0.4 }
    );
    counters.forEach((c) => io.observe(c));
  } else {
    counters.forEach((el) => {
      const target = parseFloat(el.dataset.target || '0');
      const suffix = el.dataset.suffix || '';
      el.textContent =
        (target >= 1000 ? Math.round(target).toLocaleString('fr-FR') : String(target)) + suffix;
    });
  }
</script>

<style>
  .cap {
    padding: 96px var(--pad-x-desktop);
    background: var(--color-bg-subtle);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .cap-inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }

  /* ---------- Head ---------- */
  .cap-head {
    max-width: 720px;
    margin-bottom: 56px;
  }
  .cap-overline {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    background: var(--color-primary-bg);
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    margin-bottom: 18px;
  }
  .cap-title {
    font-family: var(--font-display);
    font-size: 44px;
    line-height: 1.08;
    letter-spacing: var(--tr-display);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 18px;
  }
  .cap-title-accent { color: var(--color-primary); }
  .cap-lead {
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ---------- KPIs ---------- */
  .cap-kpis {
    list-style: none;
    margin: 0 0 64px;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .cap-kpi {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 26px 24px;
    box-shadow: var(--shadow-xs);
    position: relative;
    overflow: hidden;
    transition: transform var(--dur-base) var(--ease-standard),
                box-shadow var(--dur-base) var(--ease-standard);
  }
  .cap-kpi::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, var(--color-primary) 0%, var(--md-signal-300) 100%);
    opacity: 0.85;
  }
  .cap-kpi:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  .cap-kpi-value {
    font-family: var(--font-display);
    font-size: 44px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .cap-kpi-label {
    margin-top: 10px;
    font-size: 14px;
    font-weight: 700;
    color: var(--color-text);
  }
  .cap-kpi-kicker {
    margin-top: 4px;
    font-size: 11px;
    color: var(--color-text-muted);
    line-height: 1.45;
  }

  /* ---------- Bottom : chart + photo ---------- */
  .cap-bottom {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr);
    gap: 24px;
    align-items: stretch;
  }

  .cap-chart {
    margin: 0;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    padding: 28px 28px 22px;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
  }
  .cap-chart-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 16px;
  }
  .cap-chart-overline {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .cap-chart-title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--color-text);
    margin-top: 4px;
  }
  .cap-chart-legend {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .cap-chart-legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: linear-gradient(90deg, var(--color-primary), var(--md-signal-300));
  }
  .cap-chart-svg {
    width: 100%;
    height: auto;
    display: block;
    flex: 1;
  }
  .cap-chart-line {
    stroke-dasharray: 1800;
    stroke-dashoffset: 1800;
    animation: cap-line-draw 1.6s var(--ease-out) 0.2s forwards;
  }
  .cap-chart-area {
    opacity: 0;
    animation: cap-area-fade 1.4s var(--ease-out) 0.6s forwards;
  }
  .cap-chart-point {
    opacity: 0;
    transform-origin: center;
    animation: cap-point-pop 0.4s var(--ease-out) forwards;
    animation-delay: calc(0.9s + var(--i) * 60ms);
  }
  @keyframes cap-line-draw {
    to { stroke-dashoffset: 0; }
  }
  @keyframes cap-area-fade {
    to { opacity: 1; }
  }
  @keyframes cap-point-pop {
    from { opacity: 0; transform: scale(0.4); }
    to   { opacity: 1; transform: scale(1); }
  }

  .cap-chart-foot {
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }
  .cap-chart-trend {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--color-primary-bg);
    color: var(--color-primary);
    padding: 6px 10px;
    border-radius: var(--radius-pill);
    font-size: 12px;
    font-weight: 700;
  }
  .cap-chart-trend-arrow { font-size: 14px; }
  .cap-chart-meta {
    font-size: 11px;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
  }

  /* ---------- Photo block ---------- */
  .cap-photo {
    position: relative;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    min-height: 320px;
    box-shadow: var(--shadow-sm);
    isolation: isolate;
  }
  .cap-photo-img {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transform: scale(1.02);
    transition: transform 800ms var(--ease-out);
  }
  .cap-photo:hover .cap-photo-img { transform: scale(1.06); }
  .cap-photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(26,25,15,0) 30%, rgba(26,25,15,0.85) 100%);
    padding: 20px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    color: #fff;
  }
  .cap-photo-pill {
    align-self: flex-start;
    background: var(--md-signal-300);
    color: var(--md-brand-black);
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    font-size: 10px;
    font-family: var(--font-mono);
    font-weight: 700;
    letter-spacing: 0.08em;
  }
  .cap-photo-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }
  .cap-photo-stat-value {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    color: var(--md-signal-300);
    line-height: 1;
  }
  .cap-photo-stat-label {
    font-size: 10px;
    color: rgba(255,255,255,0.78);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 4px;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 1023px) {
    .cap { padding: 80px var(--pad-x-tablet); }
    .cap-title { font-size: 36px; }
    .cap-kpis { grid-template-columns: repeat(2, 1fr); }
    .cap-bottom { grid-template-columns: 1fr; }
    .cap-photo { min-height: 260px; }
  }
  @media (max-width: 639px) {
    .cap { padding: 64px var(--pad-x-mobile); }
    .cap-title { font-size: 28px; }
    .cap-kpi-value { font-size: 36px; }
    .cap-kpi { padding: 22px 20px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cap-chart-line,
    .cap-chart-area,
    .cap-chart-point,
    .cap-photo-img { animation: none; transition: none; }
    .cap-chart-line { stroke-dashoffset: 0; }
    .cap-chart-area { opacity: 1; }
    .cap-chart-point { opacity: 1; transform: none; }
  }
</style>
