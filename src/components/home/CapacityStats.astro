---
import { photos } from '../../config/site';

const kpis = [
  {
    value: 50000,
    prefix: '+',
    suffix: '',
    label: 'Interventions / an',
    kicker: '200 missions par jour, 300 jours par an',
  },
  {
    value: 45,
    prefix: '< ',
    suffix: ' min',
    label: 'Temps d’intervention',
    kicker: 'Sur la zone Montpellier & A9',
  },
  {
    value: 98,
    prefix: '',
    suffix: ' %',
    label: 'Satisfaction client',
    kicker: 'Enquête NF Service · 2024',
  },
  {
    value: 16,
    prefix: '',
    suffix: '',
    label: 'Dépanneurs certifiés',
    kicker: 'Formations PL, autoroute, GPL',
  },
];

const commitments = [
  { label: 'Réponse standard sous 30 sec', detail: '24h/24, par un opérateur dédié' },
  { label: 'Plateau sur place en < 45 min', detail: 'Sur l’ensemble du grand Hérault' },
  { label: 'Devis transparent sous 15 min', detail: 'Aux heures ouvrées, par retour direct' },
  { label: 'Agréés toutes assistances', detail: 'Vous êtes pris en charge sans avance' },
  { label: 'Intervention 24/7, 365 j/an', detail: 'Jamais de fermeture, jamais d’astreinte externe' },
];

// Donut : répartition par type d'intervention.
// Pourcentages indicatifs — ajuster avec les vraies données quand dispo.
const donut = [
  { label: 'Voitures légères', value: 55, color: '#2C6126' },
  { label: 'Poids lourds', value: 20, color: '#64A142' },
  { label: 'Autoroute A9', value: 15, color: '#E4E13C' },
  { label: 'Véhicules de luxe', value: 10, color: '#2C2C2A' },
];
// Pré-calcul des offsets cumulés (chacun "saute" la portion des précédents)
let acc = 0;
const donutWithOffsets = donut.map((seg) => {
  const offset = -acc;
  acc += seg.value;
  return { ...seg, offset };
});
---

<section class="cap" id="capacite" aria-labelledby="cap-title">
  <div class="cap-inner">
    <header class="cap-head">
      <div class="cap-overline">Notre capacité</div>
      <h2 class="cap-title" id="cap-title">
        Une flotte, une équipe,<br />
        <span class="cap-title-accent">des engagements qui tiennent.</span>
      </h2>
      <p class="cap-lead">
        68&nbsp;ans d’expérience, deux sites opérationnels, une présence permanente sur l’A9.
        Voici nos engagements quotidiens envers vous.
      </p>
    </header>

    <!-- KPIs -->
    <ul class="cap-kpis">
      {kpis.map((k) => (
        <li class="cap-kpi">
          <div class="cap-kpi-value">
            <span class="cap-kpi-prefix">{k.prefix}</span><span
              data-counter
              data-target={k.value}
            >0</span><span class="cap-kpi-suffix">{k.suffix}</span>
          </div>
          <div class="cap-kpi-label">{k.label}</div>
          <div class="cap-kpi-kicker">{k.kicker}</div>
        </li>
      ))}
    </ul>

    <!-- Engagements + Donut + Photo -->
    <div class="cap-bottom">
      <!-- Panel 1 : Engagements -->
      <div class="cap-panel cap-engage">
        <div class="cap-panel-head">
          <div class="cap-panel-overline">Nos engagements</div>
          <h3 class="cap-panel-title">Ce qu’on garantit, à chaque appel.</h3>
        </div>
        <ul class="cap-engage-list">
          {commitments.map((c, i) => (
            <li class="cap-engage-item" style={`--i:${i}`}>
              <span class="cap-engage-check" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="14" height="14">
                  <path d="M5 12l4 4 10-10" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
              <div class="cap-engage-body">
                <div class="cap-engage-label">{c.label}</div>
                <div class="cap-engage-detail">{c.detail}</div>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Panel 2 : Donut -->
      <div class="cap-panel cap-donut">
        <div class="cap-panel-head">
          <div class="cap-panel-overline">Répartition</div>
          <h3 class="cap-panel-title">Nos expertises.</h3>
        </div>
        <div class="cap-donut-vis">
          <svg viewBox="0 0 200 200" class="cap-donut-svg" role="img" aria-label="Répartition des interventions par type">
            <g transform="rotate(-90 100 100)">
              <circle cx="100" cy="100" r="70" fill="none" stroke="#F1EFE8" stroke-width="30" />
              {donutWithOffsets.map((seg, i) => (
                <circle
                  cx="100"
                  cy="100"
                  r="70"
                  pathLength="100"
                  fill="none"
                  stroke={seg.color}
                  stroke-width="30"
                  stroke-dasharray={`${seg.value} ${100 - seg.value}`}
                  stroke-dashoffset={seg.offset}
                  class="cap-donut-seg"
                  style={`--i:${i}; --target-dasharray: ${seg.value} ${100 - seg.value};`}
                />
              ))}
            </g>
            <text x="100" y="96" text-anchor="middle" class="cap-donut-center-top">100%</text>
            <text x="100" y="116" text-anchor="middle" class="cap-donut-center-bot">interventions</text>
          </svg>
          <ul class="cap-donut-legend">
            {donut.map((seg) => (
              <li class="cap-donut-legend-item">
                <span class="cap-donut-legend-dot" style={`background:${seg.color}`} aria-hidden="true"></span>
                <span class="cap-donut-legend-label">{seg.label}</span>
                <span class="cap-donut-legend-val mono">{seg.value}&nbsp;%</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Panel 3 : Photo -->
      <aside class="cap-photo" aria-hidden="true">
        <div class="cap-photo-img" style={`background-image: url('${photos.flotteCamions}');`}></div>
        <div class="cap-photo-overlay">
          <div class="cap-photo-pill mono">2 sites · 16 dépanneurs</div>
          <div class="cap-photo-stats">
            <div>
              <div class="cap-photo-stat-value">10+</div>
              <div class="cap-photo-stat-label">Plateaux</div>
            </div>
            <div>
              <div class="cap-photo-stat-value">4×4</div>
              <div class="cap-photo-stat-label">Tout terrain</div>
            </div>
            <div>
              <div class="cap-photo-stat-value">24/7</div>
              <div class="cap-photo-stat-label">Astreinte</div>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<script>
  // Compteurs animés au scroll
  const counters = document.querySelectorAll<HTMLElement>('[data-counter]');
  if ('IntersectionObserver' in window && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          const target = parseFloat(el.dataset.target || '0');
          const duration = 1400;
          const start = performance.now();
          const fmt = (n: number) => {
            if (target >= 1000) return Math.round(n).toLocaleString('fr-FR');
            return Math.round(n).toString();
          };
          const tick = (now: number) => {
            const t = Math.min(1, (now - start) / duration);
            const eased = 1 - Math.pow(1 - t, 3);
            el.textContent = fmt(target * eased);
            if (t < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
          io.unobserve(el);
        });
      },
      { threshold: 0.4 }
    );
    counters.forEach((c) => io.observe(c));
  } else {
    counters.forEach((el) => {
      const target = parseFloat(el.dataset.target || '0');
      el.textContent = target >= 1000 ? Math.round(target).toLocaleString('fr-FR') : String(target);
    });
  }
</script>

<style>
  .cap {
    padding: 96px var(--pad-x-desktop);
    background: var(--color-bg-subtle);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .cap-inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }

  /* ---------- Head ---------- */
  .cap-head {
    max-width: 720px;
    margin-bottom: 56px;
  }
  .cap-overline {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    background: var(--color-primary-bg);
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    margin-bottom: 18px;
  }
  .cap-title {
    font-family: var(--font-display);
    font-size: 44px;
    line-height: 1.08;
    letter-spacing: var(--tr-display);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 18px;
  }
  .cap-title-accent { color: var(--color-primary); }
  .cap-lead {
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ---------- KPIs ---------- */
  .cap-kpis {
    list-style: none;
    margin: 0 0 64px;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .cap-kpi {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 26px 24px;
    box-shadow: var(--shadow-xs);
    position: relative;
    overflow: hidden;
    transition: transform var(--dur-base) var(--ease-standard),
                box-shadow var(--dur-base) var(--ease-standard);
  }
  .cap-kpi::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, var(--color-primary) 0%, var(--md-signal-300) 100%);
    opacity: 0.85;
  }
  .cap-kpi:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  .cap-kpi-value {
    font-family: var(--font-display);
    font-size: 44px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text);
    line-height: 1;
    font-variant-numeric: tabular-nums;
    display: flex;
    align-items: baseline;
    gap: 1px;
  }
  .cap-kpi-prefix,
  .cap-kpi-suffix {
    font-size: 0.7em;
    color: var(--color-primary);
    font-weight: 700;
  }
  .cap-kpi-label {
    margin-top: 10px;
    font-size: 14px;
    font-weight: 700;
    color: var(--color-text);
  }
  .cap-kpi-kicker {
    margin-top: 4px;
    font-size: 11px;
    color: var(--color-text-muted);
    line-height: 1.45;
  }

  /* ---------- Bottom : 3 panneaux ---------- */
  .cap-bottom {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr) minmax(0, 1fr);
    gap: 16px;
    align-items: stretch;
  }
  .cap-panel {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    padding: 26px 26px 22px;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
  }
  .cap-panel-head { margin-bottom: 18px; }
  .cap-panel-overline {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .cap-panel-title {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    color: var(--color-text);
    margin: 4px 0 0;
    line-height: 1.25;
  }

  /* ---------- Engagements ---------- */
  .cap-engage-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
    flex: 1;
  }
  .cap-engage-item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    opacity: 0;
    transform: translateX(-8px);
    animation: cap-engage-in 0.5s var(--ease-out) forwards;
    animation-delay: calc(0.1s + var(--i) * 0.08s);
  }
  @keyframes cap-engage-in {
    to { opacity: 1; transform: translateX(0); }
  }
  .cap-engage-check {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--color-primary-bg);
    color: var(--color-primary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .cap-engage-body { flex: 1; }
  .cap-engage-label {
    font-size: 14px;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.3;
  }
  .cap-engage-detail {
    font-size: 12px;
    color: var(--color-text-muted);
    margin-top: 2px;
    line-height: 1.4;
  }

  /* ---------- Donut ---------- */
  .cap-donut-vis {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    flex: 1;
    justify-content: center;
  }
  .cap-donut-svg {
    width: 180px;
    height: 180px;
    flex-shrink: 0;
  }
  .cap-donut-seg {
    stroke-dasharray: 0 100 !important;
    animation: cap-donut-fill 1.2s var(--ease-out) forwards;
    animation-delay: calc(0.3s + var(--i) * 0.15s);
    transform-origin: center;
    transition: stroke-width 0.2s ease;
  }
  @keyframes cap-donut-fill {
    to { stroke-dasharray: var(--target-dasharray) !important; }
  }
  .cap-donut-seg:hover {
    stroke-width: 34;
  }
  .cap-donut-center-top {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    fill: var(--color-text);
  }
  .cap-donut-center-bot {
    font-family: var(--font-sans);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    fill: var(--color-text-muted);
  }

  .cap-donut-legend {
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .cap-donut-legend-item {
    display: grid;
    grid-template-columns: 10px 1fr auto;
    align-items: center;
    gap: 10px;
    font-size: 12px;
  }
  .cap-donut-legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .cap-donut-legend-label {
    color: var(--color-text);
    font-weight: 600;
  }
  .cap-donut-legend-val {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
  }

  /* ---------- Photo ---------- */
  .cap-photo {
    position: relative;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    isolation: isolate;
    min-height: 320px;
  }
  .cap-photo-img {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transform: scale(1.02);
    transition: transform 800ms var(--ease-out);
  }
  .cap-photo:hover .cap-photo-img { transform: scale(1.06); }
  .cap-photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(26,25,15,0) 30%, rgba(26,25,15,0.85) 100%);
    padding: 20px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    color: #fff;
  }
  .cap-photo-pill {
    align-self: flex-start;
    background: var(--md-signal-300);
    color: var(--md-brand-black);
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    font-size: 10px;
    font-family: var(--font-mono);
    font-weight: 700;
    letter-spacing: 0.08em;
  }
  .cap-photo-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }
  .cap-photo-stat-value {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    color: var(--md-signal-300);
    line-height: 1;
  }
  .cap-photo-stat-label {
    font-size: 10px;
    color: rgba(255,255,255,0.78);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 4px;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 1023px) {
    .cap { padding: 80px var(--pad-x-tablet); }
    .cap-title { font-size: 36px; }
    .cap-kpis { grid-template-columns: repeat(2, 1fr); }
    .cap-bottom {
      grid-template-columns: 1fr 1fr;
      grid-template-areas:
        'engage donut'
        'photo  photo';
    }
    .cap-engage { grid-area: engage; }
    .cap-donut { grid-area: donut; }
    .cap-photo { grid-area: photo; min-height: 260px; }
  }
  @media (max-width: 639px) {
    .cap { padding: 64px var(--pad-x-mobile); }
    .cap-title { font-size: 28px; }
    .cap-kpi-value { font-size: 36px; }
    .cap-kpi { padding: 22px 20px; }
    .cap-bottom {
      grid-template-columns: 1fr;
      grid-template-areas:
        'engage'
        'donut'
        'photo';
    }
    .cap-donut-svg { width: 160px; height: 160px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cap-engage-item { animation: none; opacity: 1; transform: none; }
    .cap-donut-seg {
      animation: none;
      stroke-dasharray: var(--target-dasharray) !important;
    }
    .cap-photo-img { transition: none; }
  }
</style>
