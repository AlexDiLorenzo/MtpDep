<section class="coverage" id="zones" aria-labelledby="coverage-title">
  <div class="coverage-inner">
    <header class="coverage-head">
      <div class="coverage-overline">Zone d’intervention</div>
      <h2 class="coverage-title" id="coverage-title">
        11&nbsp;sites pour couvrir<br />
        <span class="coverage-title-accent">l’Hérault et le Gard.</span>
      </h2>
      <p class="coverage-lead">
        Un maillage de proximité avec Montpellier comme site principal,
        des relais sur tout le grand Hérault et jusqu’en Gard.
        Délais d’intervention courts, présence permanente sur l’A9.
      </p>
    </header>

    <div class="coverage-map-wrap">
      <svg
        viewBox="120 20 770 565"
        preserveAspectRatio="xMidYMid meet"
        class="coverage-map-svg"
        role="img"
        aria-label="Carte des 11 sites Montpellier Dépannage dans l’Hérault et le Gard"
      >
        <defs>
          <linearGradient id="cov-herault" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%"   stop-color="#FBF6D0" />
            <stop offset="100%" stop-color="#F2E89E" />
          </linearGradient>
          <linearGradient id="cov-gard" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%"   stop-color="#F8F3C4" />
            <stop offset="100%" stop-color="#EDDF8C" />
          </linearGradient>
          <filter id="cov-drop" x="-5%" y="-5%" width="110%" height="115%">
            <feGaussianBlur in="SourceAlpha" stdDeviation="4" />
            <feOffset dx="0" dy="4" result="off" />
            <feComponentTransfer><feFuncA type="linear" slope="0.28" /></feComponentTransfer>
            <feMerge>
              <feMergeNode />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>
        </defs>

        <!-- Légers grands labels en watermark -->
        <text x="230" y="478" class="cov-region" font-family="'Space Grotesk', sans-serif" font-size="44" font-weight="700" letter-spacing="0.05em">HÉRAULT</text>
        <text x="690" y="178" class="cov-region" font-family="'Space Grotesk', sans-serif" font-size="36" font-weight="700" letter-spacing="0.05em">GARD</text>

        <!-- Départements -->
        <g filter="url(#cov-drop)">
          <path d={heraultPath} fill="url(#cov-herault)" stroke="#2C6126" stroke-width="1.4" stroke-linejoin="round" stroke-linecap="round" />
          <path d={gardPath}    fill="url(#cov-gard)"    stroke="#2C6126" stroke-width="1.4" stroke-linejoin="round" stroke-linecap="round" />
        </g>

        <!-- Mer (subtil indicateur sud-est) -->
        <text x="660" y="525" font-family="'DM Sans', sans-serif" font-size="11" font-style="italic" fill="rgba(44,97,38,0.5)" letter-spacing="0.2em">MER MÉDITERRANÉE</text>

        <!-- Pins -->
        {sites.map((s, i) => (
          <g class={`cov-pin${s.main ? ' is-main' : ''}`} style={`--i:${i};`}>
            {s.leader && (
              <line
                x1={s.x}
                y1={s.y}
                x2={s.leader.x}
                y2={s.leader.y}
                stroke="#1A190F"
                stroke-width="0.8"
                stroke-linecap="round"
                opacity="0.45"
              />
            )}
            {s.main && (
              <>
                <circle cx={s.x} cy={s.y} r="22" fill="#2C6126" opacity="0.18" class="cov-pin-halo" />
                <circle cx={s.x} cy={s.y} r="14" fill="#2C6126" opacity="0.35" class="cov-pin-halo cov-pin-halo--inner" />
              </>
            )}
            <circle
              cx={s.x}
              cy={s.y + 1.5}
              r={s.main ? 8.5 : 5.5}
              fill="rgba(0,0,0,0.25)"
            />
            <circle
              cx={s.x}
              cy={s.y}
              r={s.main ? 8.5 : 5}
              fill={s.main ? '#2C6126' : '#1A190F'}
              stroke="#fff"
              stroke-width={s.main ? 2.4 : 1.8}
              class="cov-pin-dot"
            />
            {s.main && (
              <circle cx={s.x} cy={s.y} r="2" fill="#E4E13C" />
            )}
            <text
              x={s.lx}
              y={s.ly}
              text-anchor={s.anchor}
              font-family="'Space Grotesk', sans-serif"
              font-size={s.main ? 14 : 11.5}
              font-weight={s.main ? 700 : 600}
              fill="#1A190F"
              class="cov-pin-label"
            >{s.name}</text>
          </g>
        ))}
      </svg>

      <!-- Badge KPI flottant -->
      <div class="coverage-badge mono">
        <span class="coverage-badge-dot" aria-hidden="true"></span>
        11 SITES · 40 DÉPANNEURS
      </div>

      <!-- Légende discrète -->
      <div class="coverage-legend">
        <span class="coverage-legend-item">
          <span class="coverage-legend-pin coverage-legend-pin--main"></span>
          Site principal
        </span>
        <span class="coverage-legend-item">
          <span class="coverage-legend-pin"></span>
          Site relais
        </span>
      </div>
    </div>
  </div>
</section>

<style>
  .coverage {
    padding: 96px var(--pad-x-desktop);
    background:
      radial-gradient(ellipse at 50% 0%, rgba(44,97,38,0.06) 0%, transparent 60%),
      var(--color-bg);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .coverage-inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }

  /* ---------- Header ---------- */
  .coverage-head {
    max-width: 760px;
    margin: 0 auto 48px;
    text-align: center;
  }
  .coverage-overline {
    display: inline-block;
    font-size: 11px;
