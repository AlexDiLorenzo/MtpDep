---
// Section « Zone d'intervention » de la home.
// La carte interactive elle-même est le composant CoverageMap
// (8 agences, marqueurs cliquables vers /agences/{slug}/).
import CoverageMap from '../CoverageMap.astro';
---

<section class="coverage" id="zones" aria-labelledby="coverage-title">
  <div class="coverage-inner">
    <header class="coverage-head">
      <div class="coverage-overline">Zone d’intervention</div>
      <h2 class="coverage-title" id="coverage-title">
        8&nbsp;agences pour couvrir<br />
        <span class="coverage-title-accent">l’Hérault et le Gard.</span>
      </h2>
      <p class="coverage-lead">
        Un maillage de proximité avec Montpellier comme agence principale,
        des agences relais sur tout le grand Hérault et jusqu’en Gard.
        Délais d’intervention courts, présence permanente sur l’A9.
      </p>
    </header>

    <div class="coverage-map-wrap">
      <CoverageMap />

      <!-- Badge KPI flottant -->
      <div class="coverage-badge mono">
        <span class="coverage-badge-dot" aria-hidden="true"></span>
        8 AGENCES · 40 DÉPANNEURS
      </div>

      <!-- Légende discrète -->
      <div class="coverage-legend">
        <span class="coverage-legend-item">
          <span class="coverage-legend-pin coverage-legend-pin--main"></span>
          Agence principale
        </span>
        <span class="coverage-legend-item">
          <span class="coverage-legend-pin"></span>
          Agence relais
        </span>
      </div>
    </div>

    <p class="coverage-hint">Survolez un marqueur, cliquez pour ouvrir la page de l’agence.</p>
  </div>
</section>

<style>
  .coverage {
    padding: 96px var(--pad-x-desktop);
    background:
      radial-gradient(ellipse at 50% 0%, rgba(44,97,38,0.06) 0%, transparent 60%),
      var(--color-bg);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .coverage-inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }

  /* ---------- Header ---------- */
  .coverage-head {
    max-width: 760px;
    margin: 0 auto 48px;
    text-align: center;
  }
  .coverage-overline {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    background: var(--color-primary-bg);
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    margin-bottom: 16px;
  }
  .coverage-title {
    font-family: var(--font-display);
    font-size: 44px;
    line-height: 1.08;
    letter-spacing: var(--tr-display);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 16px;
  }
  .coverage-title-accent { color: var(--color-primary); }
  .coverage-lead {
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ---------- Map ---------- */
  .coverage-map-wrap {
    position: relative;
    margin: 0 auto;
    max-width: 1000px;
    width: 100%;
    background:
      radial-gradient(circle at 50% 0%, #F6F5EB 0%, #ECEAD8 100%);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    aspect-ratio: 770 / 565;
  }

  /* Badge KPI flottant */
  .coverage-badge {
    position: absolute;
    top: 18px;
    left: 18px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: rgba(26,25,15,0.88);
    border-radius: var(--radius-pill);
    color: var(--md-brand-yellow);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
  }
  .coverage-badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--md-brand-yellow);
    box-shadow: 0 0 0 3px rgba(228,225,60,0.25);
    animation: cov-badge-pulse 1.8s ease-in-out infinite;
  }
  @keyframes cov-badge-pulse {
    0%, 100% { box-shadow: 0 0 0 3px rgba(228,225,60,0.25); }
    50%      { box-shadow: 0 0 0 6px rgba(228,225,60,0.08); }
  }

  /* Légende */
  .coverage-legend {
    position: absolute;
    bottom: 16px;
    right: 18px;
    display: flex;
    gap: 16px;
    padding: 8px 14px;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border: 1px solid rgba(26,25,15,0.08);
    border-radius: var(--radius-pill);
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text);
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }
  .coverage-legend-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .coverage-legend-pin {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--md-brand-black);
    border: 1.5px solid #fff;
    box-shadow: 0 0 0 1px rgba(0,0,0,0.1);
  }
  .coverage-legend-pin--main {
    width: 12px;
    height: 12px;
    background: var(--color-primary);
    border-width: 2px;
    box-shadow: 0 0 0 1px rgba(0,0,0,0.1), 0 0 0 4px rgba(44,97,38,0.15);
  }

  .coverage-hint {
    margin: 18px 0 0;
    text-align: center;
    font-size: 12px;
    color: var(--color-text-muted);
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 1023px) {
    .coverage { padding: 80px var(--pad-x-tablet); }
    .coverage-title { font-size: 36px; }
  }
  @media (max-width: 639px) {
    .coverage { padding: 64px var(--pad-x-mobile); }
    .coverage-title { font-size: 28px; }
    .coverage-badge { font-size: 10px; padding: 6px 10px; top: 12px; left: 12px; }
    .coverage-legend { bottom: 10px; right: 10px; gap: 10px; padding: 6px 10px; font-size: 10px; }
  }
</style>
