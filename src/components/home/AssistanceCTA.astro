---
import { site } from '../../config/site';

const journey = [
  {
    n: '1',
    title: 'Avez-vous une assurance ou une carte grise récente ?',
    desc: 'Presque tous les contrats incluent une assistance dépannage 24/7 — souvent gratuite, sans franchise sur les premiers kilomètres.',
  },
  {
    n: '2',
    title: 'Appelez d’abord votre assistance.',
    desc: 'Le numéro est au dos de votre carte verte (assurance) ou sur votre contrat. Vous êtes probablement déjà pris en charge.',
  },
  {
    n: '3',
    title: 'Pas d’assistance ou besoin direct ?',
    desc: 'Composez notre standard. Intervention immédiate, devis transparent, prise en charge sur l’A9 et le grand Hérault.',
  },
];
---

<section class="assist" id="assistance" aria-labelledby="assist-title">
  <div class="assist-inner">
    <header class="assist-head">
      <div class="assist-overline">Vous êtes en panne&nbsp;?</div>
      <h2 class="assist-title" id="assist-title">
        Avant tout, pensez à appeler<br />
        <span class="assist-title-accent">votre assistance.</span>
      </h2>
      <p class="assist-lead">
        9&nbsp;automobilistes sur 10 sont déjà couverts sans le savoir. Le numéro
        est au dos de votre carte verte&nbsp;— vérifiez avant tout&nbsp;:
        l’appel est gratuit, le remorquage souvent inclus.
      </p>
    </header>

    <div class="assist-grid">
      <!-- Carte qui se retourne -->
      <div class="assist-card-wrap">
        <button
          type="button"
          class="assist-card"
          aria-label="Retourner la carte d'assistance pour voir le numéro"
          data-flip
        >
          <div class="assist-card-inner">
            <!-- Recto : Certificat d'Assurance (carte verte FR) -->
            <div class="assist-card-face assist-card-front">
              <div class="assist-card-watermark" aria-hidden="true">
                <span>CA</span>
              </div>
              <div class="assist-card-border" aria-hidden="true"></div>

              <h3 class="assist-card-cert-title">CERTIFICAT D'ASSURANCE</h3>

              <div class="assist-card-field assist-card-field-period">
                <div class="assist-card-field-row">
                  <span class="assist-card-field-label">du</span>
                  <span class="assist-card-field-value mono">01.01.2026</span>
                  <span class="assist-card-field-label">au</span>
                  <span class="assist-card-field-value mono">31.12.2026</span>
                </div>
              </div>

              <div class="assist-card-field assist-card-field-id">
                <span class="assist-card-field-mini-label">Identification</span>
                <span class="assist-card-field-id-value mono">AB-123-CD</span>
              </div>

              <div class="assist-card-num">
                <span class="assist-card-num-label">N°</span>
                <span class="assist-card-num-value mono">2026 04 67 421 431</span>
              </div>

              <div class="assist-card-flip-hint" aria-hidden="true">
                <span class="assist-card-flip-icon">↻</span>
                Cliquez pour retourner
              </div>
            </div>

            <!-- Verso : numéro d'assistance mis en évidence -->
            <div class="assist-card-face assist-card-back">
              <div class="assist-card-back-strip" aria-hidden="true"></div>
              <div class="assist-card-back-overline">Assistance 24/7 — au dos de votre carte</div>
              <div class="assist-card-back-phone">
                <span class="assist-card-back-phone-icon" aria-hidden="true">☎</span>
                <span class="assist-card-back-phone-num mono">0&nbsp;800&nbsp;XX&nbsp;XX&nbsp;XX</span>
              </div>
              <div class="assist-card-back-note">
                C’est ce numéro qu’il faut composer en premier. <br />
                Appel gratuit, remorquage souvent inclus dans votre contrat.
              </div>
              <div class="assist-card-back-arrow" aria-hidden="true">↻</div>
            </div>
          </div>
        </button>

        <div class="assist-card-caption">
          Carte d’illustration — votre numéro d’assistance se trouve
          au dos de la vraie carte verte ou sur votre contrat d’assurance.
        </div>
      </div>

      <!-- Parcours -->
      <ol class="assist-steps">
        {journey.map((s) => (
          <li class="assist-step">
            <div class="assist-step-num">{s.n}</div>
            <div class="assist-step-body">
              <div class="assist-step-title">{s.title}</div>
              <div class="assist-step-desc">{s.desc}</div>
            </div>
          </li>
        ))}
      </ol>
    </div>

    <!-- Fallback : appel direct + CTA devis -->
    <div class="assist-fallback">
      <div class="assist-fallback-copy">
        <div class="assist-fallback-overline">Pas d’assistance ou besoin direct&nbsp;?</div>
        <div class="assist-fallback-title">Appelez le standard 24/7 ou faites une demande de devis.</div>
      </div>
      <div class="assist-fallback-actions">
        <a href={site.phone.href} class="assist-fallback-phone mono">
          <span aria-hidden="true">☎</span> {site.phone.display}
        </a>
        <a href="#devis" class="assist-fallback-quote">Demande de devis →</a>
      </div>
    </div>

    <!-- Formulaire devis -->
    <div class="devis-panel" id="devis">
      <div class="devis-head">
        <div class="devis-overline">Demande de devis</div>
        <h3 class="devis-title">Décrivez votre besoin en quelques champs.</h3>
        <p class="devis-lead">
          Nous vous rappelons sous 2&nbsp;heures aux horaires ouvrés.
          Demande sans engagement, traitée par un dépanneur.
        </p>
        <p class="devis-lead-mail">
          Ou par email&nbsp;: <a href="mailto:pec@montpellierdepannage.com">pec@montpellierdepannage.com</a>
        </p>
      </div>

      <form class="devis-form" id="devis-form" novalidate>
        <div class="devis-grid">
          <label class="devis-field">
            <span class="devis-label">Nom &amp; prénom</span>
            <input type="text" name="name" autocomplete="name" maxlength="120" />
          </label>

          <label class="devis-field">
            <span class="devis-label">Téléphone <em class="req">*</em></span>
            <input
              type="tel"
              name="phone"
              autocomplete="tel"
              required
              maxlength="30"
              placeholder="06 12 34 56 78"
            />
          </label>

          <label class="devis-field">
            <span class="devis-label">Email</span>
            <input type="email" name="email" autocomplete="email" maxlength="160" />
          </label>

          <fieldset class="devis-field devis-field-radio">
            <legend class="devis-label">Type de véhicule</legend>
            <div class="devis-radios">
              <label><input type="radio" name="vehicle_type" value="VL" /> <span>VL</span></label>
              <label><input type="radio" name="vehicle_type" value="UTILITAIRE" /> <span>Utilitaire</span></label>
              <label><input type="radio" name="vehicle_type" value="PL" /> <span>Poids lourd</span></label>
            </div>
          </fieldset>

          <label class="devis-field devis-field-full">
            <span class="devis-label">Lieu de la panne</span>
            <input type="text" name="location" maxlength="200" placeholder="Adresse, sortie A9, lieu-dit…" />
          </label>

          <label class="devis-field devis-field-full">
            <span class="devis-label">Destination souhaitée</span>
            <input type="text" name="destination" maxlength="200" placeholder="Garage, domicile, adresse précise…" />
          </label>

          <label class="devis-field devis-field-full">
            <span class="devis-label">Détails</span>
            <textarea name="details" rows="3" maxlength="2000" placeholder="Marque/modèle, nature du problème, accès…"></textarea>
          </label>
        </div>

        <!-- honeypot anti-bot -->
        <div class="devis-honeypot" aria-hidden="true">
          <label>Site web (laisser vide)
            <input type="text" name="website" tabindex="-1" autocomplete="off" />
          </label>
        </div>

        <label class="devis-consent">
          <input type="checkbox" name="consent_rgpd" required />
          <span>
            J’accepte que mes informations soient utilisées pour traiter ma demande de devis.
            Données conservées le temps du suivi commercial, jamais transmises à un tiers.
          </span>
        </label>

        <div class="devis-submit-row">
          <button type="submit" class="devis-submit">
            <span class="devis-submit-label">Envoyer la demande</span>
            <span class="devis-submit-spinner" aria-hidden="true"></span>
          </button>
          <span class="devis-submit-note">Réponse sous 2&nbsp;h aux heures ouvrées</span>
        </div>

        <div class="devis-result" role="status" aria-live="polite"></div>
      </form>
    </div>
  </div>
</section>

<script>
  // Flip au clic + au focus clavier (Enter/Espace géré nativement par <button>)
  const cards = document.querySelectorAll<HTMLButtonElement>('[data-flip]');
  cards.forEach((card) => {
    card.addEventListener('click', () => {
      const flipped = card.getAttribute('aria-pressed') === 'true';
      card.setAttribute('aria-pressed', String(!flipped));
      card.classList.toggle('is-flipped', !flipped);
    });
  });

  // Soumission du formulaire de devis
  const form = document.getElementById('devis-form') as HTMLFormElement | null;
  if (form) {
    const result = form.querySelector<HTMLDivElement>('.devis-result')!;
    const submit = form.querySelector<HTMLButtonElement>('.devis-submit')!;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      result.textContent = '';
      result.className = 'devis-result';

      const data = new FormData(form);
      const payload = {
        name: String(data.get('name') || ''),
        phone: String(data.get('phone') || ''),
        email: String(data.get('email') || ''),
        vehicle_type: String(data.get('vehicle_type') || ''),
        location: String(data.get('location') || ''),
        destination: String(data.get('destination') || ''),
        details: String(data.get('details') || ''),
        consent_rgpd: data.get('consent_rgpd') === 'on',
        website: String(data.get('website') || ''),
      };

      if (!payload.phone.trim()) {
        result.textContent = 'Merci d’indiquer un numéro de téléphone.';
        result.classList.add('devis-result-err');
        return;
      }
      if (!payload.consent_rgpd) {
        result.textContent = 'Merci d’accepter le traitement de vos données.';
        result.classList.add('devis-result-err');
        return;
      }

      submit.disabled = true;
      submit.classList.add('is-loading');

      try {
        const res = await fetch('/api/devis', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const json = (await res.json().catch(() => ({}))) as { ok?: boolean; error?: string };
        if (!res.ok || !json.ok) {
          throw new Error(json.error || `HTTP ${res.status}`);
        }
        result.textContent = 'Demande envoyée. Nous vous rappelons sous 2 heures.';
        result.classList.add('devis-result-ok');
        form.reset();
      } catch (err) {
        const msg = err instanceof Error ? err.message : 'erreur';
        result.textContent = `Échec de l’envoi (${msg}). Vous pouvez aussi appeler directement.`;
        result.classList.add('devis-result-err');
      } finally {
        submit.disabled = false;
        submit.classList.remove('is-loading');
      }
    });
  }
</script>

<style>
  .assist {
    padding: 96px var(--pad-x-desktop);
    background: var(--color-bg);
    position: relative;
    overflow: hidden;
  }
  .assist::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 12% 10%, rgba(44,97,38,0.05) 0%, transparent 55%),
      radial-gradient(ellipse at 88% 90%, rgba(228,225,60,0.08) 0%, transparent 55%);
    pointer-events: none;
  }
  .assist-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    position: relative;
  }

  /* ---------- Head ---------- */
  .assist-head {
    max-width: 720px;
    margin-bottom: 56px;
  }
  .assist-overline {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    background: var(--color-primary-bg);
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    margin-bottom: 18px;
  }
  .assist-title {
    font-family: var(--font-display);
    font-size: 44px;
    line-height: 1.08;
    letter-spacing: var(--tr-display);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 18px;
  }
  .assist-title-accent { color: var(--color-primary); }
  .assist-lead {
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ---------- Grid carte + steps ---------- */
  .assist-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
    gap: 64px;
    align-items: center;
    margin-bottom: 56px;
  }

  /* ---------- Carte 3D flip ---------- */
  .assist-card-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }
  .assist-card {
    width: 100%;
    max-width: 360px;
    aspect-ratio: 1 / 0.86;
    perspective: 1400px;
    background: transparent;
    border: 0;
    padding: 0;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }
  .assist-card:focus-visible {
    outline: 3px solid var(--md-signal-300);
    outline-offset: 6px;
    border-radius: var(--radius-xl);
  }
  .assist-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 900ms cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: transform;
  }
  .assist-card.is-flipped .assist-card-inner {
    transform: rotateY(180deg);
  }
  /* Léger flottement au survol pour signaler l'interactivité */
  @media (hover: hover) {
    .assist-card:hover .assist-card-inner {
      transform: translateY(-4px) rotateY(0);
    }
    .assist-card.is-flipped:hover .assist-card-inner {
      transform: translateY(-4px) rotateY(180deg);
    }
  }

  .assist-card-face {
    position: absolute;
    inset: 0;
    border-radius: 6px;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    box-shadow:
      0 24px 60px -20px rgba(26,25,15,0.45),
      0 8px 18px -6px rgba(26,25,15,0.25);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-align: left;
  }

  /* ----- Front : Certificat d'Assurance officiel ----- */
  .assist-card-front {
    /* Vert sauge clair, ton officiel de la carte verte FR */
    background:
      linear-gradient(180deg, #B5D6B2 0%, #A6CDA4 50%, #98C399 100%);
    color: #1a1a1a;
    padding: 0;
    font-family: 'Times New Roman', 'Liberation Serif', Georgia, serif;
  }

  /* Filigrane "CA" répété en mosaïque */
  .assist-card-front::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 80 80' opacity='0.55'><text x='4' y='22' font-family='serif' font-size='18' font-weight='700' fill='%2381AE85'>CA</text><text x='44' y='42' font-family='serif' font-size='18' font-weight='700' fill='%2381AE85'>CA</text><text x='4' y='62' font-family='serif' font-size='18' font-weight='700' fill='%2381AE85'>CA</text><text x='44' y='82' font-family='serif' font-size='18' font-weight='700' fill='%2381AE85'>CA</text></svg>");
    background-size: 80px 80px;
    background-repeat: repeat;
    opacity: 0.55;
    pointer-events: none;
  }

  /* Grand "CA" stylisé au centre */
  .assist-card-watermark {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 1;
  }
  .assist-card-watermark span {
    font-family: 'Times New Roman', 'Liberation Serif', Georgia, serif;
    font-size: 220px;
    font-weight: 700;
    color: rgba(110, 155, 113, 0.45);
    letter-spacing: -0.04em;
    line-height: 0.8;
    -webkit-text-stroke: 1px rgba(80, 130, 85, 0.55);
    text-stroke: 1px rgba(80, 130, 85, 0.55);
    transform: translateY(8px);
  }

  /* Bordure intérieure imitant le cadre officiel */
  .assist-card-border {
    position: absolute;
    inset: 8px;
    border: 1.5px solid rgba(60, 110, 65, 0.35);
    border-radius: 2px;
    pointer-events: none;
    z-index: 2;
  }
  .assist-card-border::after {
    content: '';
    position: absolute;
    inset: 4px;
    border: 1px dashed rgba(60, 110, 65, 0.25);
    border-radius: 1px;
  }

  .assist-card-cert-title {
    position: relative;
    z-index: 3;
    font-family: 'Times New Roman', 'Liberation Serif', Georgia, serif;
    font-size: 16px;
    font-weight: 700;
    text-align: center;
    letter-spacing: 0.04em;
    color: #111;
    margin: 22px 24px 16px;
    text-transform: uppercase;
  }

  /* Champs noirs (cadres officiels) */
  .assist-card-field {
    position: relative;
    z-index: 3;
    margin: 0 24px 12px;
    background: transparent;
    border: 1.4px solid #111;
    padding: 8px 10px;
    min-height: 30px;
    display: flex;
    align-items: center;
  }
  .assist-card-field-period .assist-card-field-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
    flex: 1;
    flex-wrap: nowrap;
    font-size: 12px;
  }
  .assist-card-field-label {
    font-family: 'Times New Roman', serif;
    font-size: 13px;
    font-weight: 400;
    color: #111;
    font-style: italic;
  }
  .assist-card-field-value {
    flex: 1;
    border-bottom: 1px solid #111;
    padding: 0 4px 1px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: #111;
    text-align: center;
  }
  .assist-card-field-id {
    flex-direction: column;
    align-items: stretch;
    padding: 4px 10px 8px;
  }
  .assist-card-field-mini-label {
    font-family: 'Times New Roman', serif;
    font-size: 10.5px;
    font-style: italic;
    text-align: center;
    color: #111;
    margin-bottom: 2px;
  }
  .assist-card-field-id-value {
    align-self: center;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: #111;
    border-bottom: 1px solid #111;
    padding: 0 24px 1px;
    min-width: 60%;
    text-align: center;
  }

  .assist-card-num {
    position: relative;
    z-index: 3;
    margin: auto 24px 16px;
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-family: 'Times New Roman', serif;
    font-size: 12px;
  }
  .assist-card-num-label { font-weight: 400; color: #111; }
  .assist-card-num-value {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: #1a1a1a;
  }

  /* Hint flip discret en bas à droite */
  .assist-card-flip-hint {
    position: absolute;
    bottom: 14px;
    right: 18px;
    z-index: 4;
    font-family: var(--font-sans);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #2C6126;
    background: rgba(255,255,255,0.85);
    padding: 5px 9px;
    border-radius: var(--radius-pill);
    border: 1px solid rgba(44,97,38,0.3);
    display: inline-flex;
    align-items: center;
    gap: 5px;
    box-shadow: 0 2px 6px rgba(0,0,0,0.08);
  }
  .assist-card-flip-icon {
    display: inline-block;
    font-size: 11px;
    animation: assist-flip-hint 2.4s ease-in-out infinite;
  }
  @keyframes assist-flip-hint {
    0%, 60%, 100% { transform: rotate(0); }
    70% { transform: rotate(-90deg); }
    85% { transform: rotate(-180deg); }
  }

  /* ----- Back : numéro d'assistance ----- */
  .assist-card-back {
    background:
      linear-gradient(160deg, #FFFFFF 0%, #F6F5EB 60%, #EDEBD3 100%);
    color: var(--color-text);
    transform: rotateY(180deg);
    padding: 26px 28px;
    justify-content: space-between;
  }
  .assist-card-back::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 90% 90%, rgba(228,225,60,0.25) 0%, transparent 45%);
    pointer-events: none;
  }
  .assist-card-back-strip {
    position: absolute;
    top: 18px;
    left: 0;
    right: 0;
    height: 36px;
    background: var(--md-stone-900);
  }
  .assist-card-back-overline {
    margin-top: 70px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    position: relative;
  }
  .assist-card-back-phone {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--md-signal-300);
    color: var(--md-brand-black);
    padding: 14px 16px;
    border-radius: var(--radius-lg);
    box-shadow: 0 6px 18px rgba(228,225,60,0.45);
    position: relative;
    border: 2px solid var(--md-brand-black);
  }
  .assist-card-back-phone-icon {
    font-size: 22px;
    line-height: 1;
  }
  .assist-card-back-phone-num {
    font-family: var(--font-mono);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }
  .assist-card-back-note {
    font-size: 11px;
    line-height: 1.5;
    color: var(--color-text-muted);
    position: relative;
  }
  .assist-card-back-arrow {
    position: absolute;
    bottom: 14px;
    right: 16px;
    font-size: 14px;
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .assist-card-caption {
    font-size: 11px;
    line-height: 1.5;
    color: var(--color-text-muted);
    text-align: center;
    max-width: 360px;
  }

  /* ---------- Steps ---------- */
  .assist-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .assist-step {
