---
import { certifications } from '../../config/site';
---

<section class="cert-band" aria-labelledby="cert-title">
  <div class="cert-inner">
    <div class="cert-title" id="cert-title">Labels et certifications</div>
    <div class="cert-logos">
      <img src={certifications.nfService} alt="NF Service — certification AFNOR" height="58" loading="lazy" />
      <img src={certifications.envol} alt="Signataires Envol — engagement environnemental" height="48" loading="lazy" />
      <img src={certifications.oleo100} alt="Oleo 100 — flotte au biocarburant 100% Colza" height="54" loading="lazy" />
    </div>
  </div>
</section>

<style>
  .cert-band {
    background: var(--color-bg-subtle);
    border-bottom: 1px solid var(--color-border);
    padding: 32px var(--pad-x-desktop);
  }
  .cert-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }
  .cert-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    flex-shrink: 0;
  }
  .cert-logos {
    display: flex;
    align-items: center;
    gap: 40px;
    flex: 1;
    justify-content: flex-end;
    flex-wrap: wrap;
  }
  .cert-logos img {
    height: auto;
    max-height: 58px;
    width: auto;
    opacity: 1;
    transition: opacity var(--dur-base) var(--ease-standard);
  }
  .cert-logos img:hover { opacity: 0.85; }

  @media (max-width: 1023px) {
    .cert-band { padding: 28px var(--pad-x-tablet); }
    .cert-logos { gap: 32px; }
  }
  @media (max-width: 767px) {
    .cert-band { padding: 24px var(--pad-x-mobile); }
    .cert-inner { flex-direction: column; gap: 20px; }
    .cert-logos { justify-content: center; gap: 24px; }
    .cert-logos img { max-height: 44px; }
  }
</style>
