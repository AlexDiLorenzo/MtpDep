---
import { site, photos } from '../../config/site';
import ReviewQr from './ReviewQr.astro';

const stats = [
  { value: '30+', label: "Années d'expérience", kicker: 'Entreprise familiale' },
  { value: '40', label: 'Plateaux de remorquage', kicker: 'Dont 4×4 et rabaissés' },
  { value: '4', label: 'Pays couverts', kicker: 'FR · BE · IT · ES' },
  { value: 'A9', label: 'Agréé autoroutes', kicker: 'Vinci partenaire' },
];
---

<section class="hero" style={`--hero-bg: url('${photos.heroComedie}');`}>
  <ReviewQr />

  <div class="hero-content">
    <div class="hero-pill">
      <span class="hero-pill-dot" aria-hidden="true"></span>
      Intervention 24H/24 · 7J/7
    </div>

    <h1 class="hero-title">
      Remorquage et dépannage,<br />
      <span class="hero-title-accent">24 heures sur 24.</span>
    </h1>

    <p class="hero-lead">
      Plus de 40 plateaux, véhicules 4×4, agréés autoroutes A9. Intervention en France,
      Belgique, Italie et Espagne. Voitures, poids lourds, véhicules de luxe.
    </p>

    <div class="hero-cta">
      <a href={site.phone.href} class="hero-phone" data-call-source="hero">
        <span class="hero-phone-icon" aria-hidden="true">☎</span>
        <span class="hero-phone-text">
          <span class="hero-phone-kicker">Urgence 24/7</span>
          <span class="hero-phone-number mono">{site.phone.display}</span>
        </span>
      </a>
      <a href="#assistance" class="hero-quote">
        Vous êtes en panne&nbsp;?
        <span class="hero-quote-arrow" aria-hidden="true">→</span>
      </a>
    </div>

    <ul class="hero-reassure">
      <li><span class="hero-reassure-check" aria-hidden="true">✓</span> Certifié NF&nbsp;Service</li>
      <li><span class="hero-reassure-check" aria-hidden="true">✓</span> Agréé autoroutes A9</li>
      <li><span class="hero-reassure-check" aria-hidden="true">✓</span> Toutes assistances, sans avance de frais</li>
    </ul>
  </div>

  <div class="hero-trust">
    <ul class="hero-stats">
      {stats.map((s) => (
        <li class="hero-stat">
          <div class="hero-stat-value">{s.value}</div>
          <div class="hero-stat-label">{s.label}</div>
          <div class="hero-stat-kicker">{s.kicker}</div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 620px;
    background-image:
      radial-gradient(ellipse at 20% 15%, rgba(44,97,38,0.30) 0%, transparent 55%),
      linear-gradient(90deg, rgba(26,25,15,0.72) 0%, rgba(26,25,15,0.30) 62%, transparent 100%),
      linear-gradient(180deg, rgba(26,25,15,0.55) 0%, rgba(26,25,15,0.60) 45%, rgba(26,25,15,0.88) 100%),
      var(--hero-bg);
    background-size: cover;
    background-position: center;
    color: #fff;
    padding: 92px var(--pad-x-desktop) 60px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 44px;
  }
  /* Voile de grain subtil pour la profondeur */
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 120%, rgba(228,225,60,0.10) 0%, transparent 60%);
    pointer-events: none;
  }

  /* ---------- Animations d'entrée (au chargement) ---------- */
  @keyframes hero-in {
    from { opacity: 0; transform: translateY(26px); }
    to   { opacity: 1; transform: none; }
  }
  .hero-pill,
  .hero-title,
  .hero-lead,
  .hero-cta,
  .hero-reassure,
  .hero-trust {
    animation: hero-in 0.8s var(--ease-reveal) both;
  }
  .hero-title    { animation-delay: 0.08s; }
  .hero-lead     { animation-delay: 0.16s; }
  .hero-cta      { animation-delay: 0.24s; }
  .hero-reassure { animation-delay: 0.32s; }
  .hero-trust    { animation-delay: 0.40s; }
  @media (prefers-reduced-motion: reduce) {
    .hero-pill, .hero-title, .hero-lead, .hero-cta, .hero-reassure, .hero-trust {
      animation: none;
    }
  }

  .hero-content {
    max-width: var(--container-max);
    margin: 0 auto;
    width: 100%;
  }

  .hero-pill {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 14px;
    background: rgba(228,225,60,0.95);
    border-radius: var(--radius-pill);
    color: var(--md-brand-black);
    margin-bottom: 28px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .hero-pill-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--md-brand-green);
    box-shadow: 0 0 0 3px rgba(44,97,38,0.25);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: 76px;
    line-height: 1.01;
    font-weight: 700;
    letter-spacing: -0.035em;
    margin: 0 0 20px;
    max-width: 900px;
    color: #fff;
    text-shadow: 0 2px 30px rgba(0,0,0,0.25);
  }
  .hero-title-accent { color: var(--md-brand-yellow); }

  .hero-lead {
    font-size: 18px;
    line-height: 1.55;
    max-width: 620px;
    color: rgba(255,255,255,0.88);
    margin: 0 0 36px;
  }

  .hero-cta {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }

  /* ---------- Ligne de réassurance ---------- */
  .hero-reassure {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 10px 22px;
  }
  .hero-reassure li {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 600;
    color: rgba(255,255,255,0.82);
  }
  .hero-reassure-check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: rgba(228,225,60,0.9);
    color: var(--md-brand-black);
    font-size: 11px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .hero-phone {
    padding: 16px 24px;
    background: var(--md-brand-yellow);
    color: var(--md-brand-black);
    border-radius: var(--radius-lg);
    text-decoration: none;
    font-size: 15px;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 12px;
    box-shadow: 0 4px 14px rgba(0,0,0,0.25);
    transition: background-color var(--dur-base) var(--ease-standard), transform var(--dur-base) var(--ease-standard);
  }
  .hero-phone:hover { background: var(--color-accent-hover); }
  .hero-phone-icon { font-size: 22px; }
  .hero-phone-text { display: flex; flex-direction: column; }
  .hero-phone-kicker {
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.7;
    font-weight: 700;
  }
  .hero-phone-number {
    font-family: var(--font-mono);
    font-size: 17px;
    letter-spacing: -0.01em;
  }

  .hero-quote {
    padding: 16px 24px;
    background: var(--color-primary);
    color: #fff;
    border-radius: var(--radius-lg);
    text-decoration: none;
    font-size: 15px;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 10px;
    box-shadow: 0 4px 14px rgba(44,97,38,0.45);
    border: 1px solid rgba(228,225,60,0.3);
    transition: background-color var(--dur-base) var(--ease-standard);
  }
  .hero-quote:hover { background: var(--color-primary-hover); }
  .hero-quote-arrow { opacity: 0.8; transition: transform var(--dur-base) var(--ease-standard); }
  .hero-quote:hover .hero-quote-arrow { transform: translateX(3px); }

  .hero-trust {
    max-width: var(--container-max);
    margin: 0 auto;
    width: 100%;
    border-top: 1px solid rgba(255,255,255,0.2);
    padding-top: 24px;
  }
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }
  .hero-stat {
    padding: 18px 20px;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.14);
    border-radius: var(--radius-xl);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    transition: background-color var(--dur-base) var(--ease-standard),
                border-color var(--dur-base) var(--ease-standard),
                transform var(--dur-base) var(--ease-standard);
  }
  .hero-stat:hover {
    background: rgba(255,255,255,0.11);
    border-color: rgba(228,225,60,0.4);
    transform: translateY(-2px);
  }
  .hero-stat-value {
    font-family: var(--font-display);
    font-size: 40px;
    font-weight: 700;
    color: var(--md-brand-yellow);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .hero-stat-label {
    font-size: 13px;
    color: rgba(255,255,255,0.9);
    margin-top: 8px;
    font-weight: 600;
  }
  .hero-stat-kicker {
    font-size: 10px;
    color: rgba(255,255,255,0.55);
    margin-top: 2px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 700;
  }

  /* Responsive */
  @media (max-width: 1023px) {
    .hero { padding: 72px var(--pad-x-tablet) 48px; }
    .hero-title { font-size: 52px; }
    .hero-stats { grid-template-columns: repeat(2, 1fr); gap: 24px; }
  }

  @media (max-width: 767px) {
    .hero { padding: 56px var(--pad-x-mobile) 40px; min-height: 460px; }
    .hero-title { font-size: 36px; }
    .hero-lead { font-size: 16px; }
    .hero-cta { flex-direction: column; align-items: stretch; gap: 10px; margin-bottom: 36px; }
    .hero-phone, .hero-quote { width: 100%; justify-content: center; }
    .hero-phone-text { align-items: flex-start; }
    .hero-stat-value { font-size: 32px; }
  }
</style>
