---
import { photos } from '../../config/site';

const services = [
  { tag: '01', title: 'Remorquage VL & véhicules de luxe', desc: 'Voitures en panne ou accidentées, accès sous-sols, plateaux rabaissés adaptés aux véhicules de prestige.', image: photos.porschePlateau },
  { tag: '02', title: 'Remorquage poids lourds', desc: 'Flotte 4×4 avec bras, plateaux PL. Récupération de tout gabarit, jour et nuit.', image: photos.plRecuperation },
  { tag: '03', title: 'Autoroute A9', desc: 'Agréés autoroutes, partenaires Vinci. Intervention rapide sur le réseau Hérault.', image: photos.heroA9 },
  { tag: '04', title: 'Transport international', desc: 'France, Belgique, Italie, Espagne. Rapatriement de véhicules accidentés.', image: photos.plRenversement },
  { tag: '05', title: 'Mécanique · GPL · Clim', desc: 'Entretien véhicules, installation systèmes GPL, révision climatisation.', image: photos.flotteDepot },
  { tag: '06', title: 'Location 24/7', desc: 'Service de location disponible en continu, véhicules de remplacement.', image: photos.flotteDepot },
];
---

<section class="services" id="services">
  <div class="services-inner">
    <header class="services-head">
      <div>
        <div class="services-overline">Nos activités</div>
        <h2 class="services-title">
          Un savoir-faire à votre service<br />pour chaque situation.
        </h2>
      </div>
      <a href="#" class="services-all">Voir tous les services →</a>
    </header>

    <div class="services-grid">
      {services.map((s) => (
        <article class="service-card">
          <div class="service-card-img" style={`--svc-img: url('${s.image}');`}>
            <span class="service-card-tag mono">{s.tag}</span>
          </div>
          <div class="service-card-body">
            <h3 class="service-card-title">{s.title}</h3>
            <p class="service-card-desc">{s.desc}</p>
            <a href="#" class="service-card-link">En savoir plus <span aria-hidden="true">→</span></a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    padding: 80px var(--pad-x-desktop);
    background: var(--color-bg);
  }
  .services-inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .services-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 40px;
    flex-wrap: wrap;
    gap: 20px;
  }
  .services-overline {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 10px;
  }
  .services-title {
    font-family: var(--font-display);
    font-size: 40px;
    margin: 0;
    color: var(--color-text);
    letter-spacing: var(--tr-display);
    line-height: 1.1;
    font-weight: 700;
  }
  .services-all {
    font-size: 13px;
    color: var(--color-primary);
    font-weight: 700;
    text-decoration: none;
    border: 1px solid var(--color-border);
    padding: 10px 16px;
    border-radius: var(--radius-md);
    transition: background-color var(--dur-base) var(--ease-standard), border-color var(--dur-base) var(--ease-standard);
  }
  .services-all:hover {
    background: var(--color-primary-bg);
    border-color: var(--color-primary);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .service-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: var(--shadow-sm);
    transition: transform var(--dur-base) var(--ease-standard), box-shadow var(--dur-base) var(--ease-standard);
  }
  .service-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  .service-card-img {
    height: 160px;
    background-image: linear-gradient(180deg, rgba(26,25,15,0) 40%, rgba(26,25,15,0.7) 100%), var(--svc-img);
    background-size: cover;
    background-position: center;
    position: relative;
    transition: transform var(--dur-base) var(--ease-standard);
  }
  .service-card:hover .service-card-img { transform: scale(1.03); }
  .service-card-tag {
    position: absolute;
    top: 12px;
    left: 12px;
    padding: 4px 8px;
    background: var(--md-brand-yellow);
    color: var(--md-brand-black);
    border-radius: var(--radius-xs);
    font-size: 10px;
    font-family: var(--font-mono);
    font-weight: 700;
    letter-spacing: 0.05em;
  }
  .service-card-body {
    padding: 20px 22px 22px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .service-card-title {
    font-size: 17px;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 8px;
    font-family: var(--font-sans);
  }
  .service-card-desc {
    font-size: 13px;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.55;
    flex: 1;
  }
  .service-card-link {
    margin-top: 16px;
    font-size: 12px;
    color: var(--color-primary);
    font-weight: 700;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .service-card-link span { transition: transform var(--dur-base) var(--ease-standard); }
  .service-card:hover .service-card-link span { transform: translateX(3px); }

  @media (max-width: 1023px) {
    .services { padding: 72px var(--pad-x-tablet); }
    .services-grid { grid-template-columns: repeat(2, 1fr); }
    .services-title { font-size: 32px; }
  }
  @media (max-width: 639px) {
    .services { padding: 56px var(--pad-x-mobile); }
    .services-grid { grid-template-columns: 1fr; }
    .services-title { font-size: 28px; }
  }
</style>
