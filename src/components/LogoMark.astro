---
interface Props {
  size?: number;
  class?: string;
  alt?: string;
}
const { size = 32, class: className, alt = 'Montpellier Dépannage' } = Astro.props;
---

<img
  src="/img/logo-mdp.png"
  alt={alt}
  class:list={['logo-mark', className]}
  loading="eager"
  decoding="async"
  style={`height:${size}px;width:auto;`}
/>

<style>
  .logo-mark {
    flex-shrink: 0;
    display: block;
    object-fit: contain;
  }
</style>
