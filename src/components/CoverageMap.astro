---
// Carte interactive des 8 agences Montpellier Dépannage.
// Chaque marqueur est un lien vers /agences/{slug}/ avec une
// info-bulle au survol. Partagée par la home (CoverageBand) et
// par la page /agences/.

import { agences } from '../data/agences';
import { heraultPath, gardPath, mapViewBox, mapLabels } from '../data/coverage-map';

// Jointure données métier (x/y, slug) ↔ mise en page carte (libellé).
const markers = agences.map((a) => {
  const label = mapLabels[a.slug];
  return {
    slug: a.slug,
    societe: a.societe,
    x: a.carte.x,
    y: a.carte.y,
    principal: !!a.principal,
    ...label,
  };
});
---

<svg
  viewBox={mapViewBox}
  preserveAspectRatio="xMidYMid meet"
  class="cmap"
  role="img"
  aria-label="Carte interactive des 8 agences Montpellier Dépannage dans l'Hérault et le Gard"
>
  <defs>
    <linearGradient id="cmap-herault" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#FBF6D0" />
      <stop offset="100%" stop-color="#F2E89E" />
    </linearGradient>
    <linearGradient id="cmap-gard" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#F8F3C4" />
      <stop offset="100%" stop-color="#EDDF8C" />
    </linearGradient>
    <filter id="cmap-drop" x="-5%" y="-5%" width="110%" height="115%">
      <feGaussianBlur in="SourceAlpha" stdDeviation="4" />
      <feOffset dx="0" dy="4" result="off" />
      <feComponentTransfer><feFuncA type="linear" slope="0.28" /></feComponentTransfer>
      <feMerge>
        <feMergeNode />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>
  </defs>

  {/* Watermarks de département */}
  <text x="230" y="478" class="cmap-region" font-family="'Space Grotesk', sans-serif" font-size="44" font-weight="700" letter-spacing="0.05em">HÉRAULT</text>
  <text x="690" y="178" class="cmap-region" font-family="'Space Grotesk', sans-serif" font-size="36" font-weight="700" letter-spacing="0.05em">GARD</text>

  {/* Départements */}
  <g filter="url(#cmap-drop)">
    <path d={heraultPath} fill="url(#cmap-herault)" stroke="#2C6126" stroke-width="1.4" stroke-linejoin="round" stroke-linecap="round" />
    <path d={gardPath} fill="url(#cmap-gard)" stroke="#2C6126" stroke-width="1.4" stroke-linejoin="round" stroke-linecap="round" />
  </g>

  <text x="660" y="525" font-family="'DM Sans', sans-serif" font-size="11" font-style="italic" fill="rgba(44,97,38,0.5)" letter-spacing="0.2em">MER MÉDITERRANÉE</text>

  {/* Marqueurs cliquables */}
  {markers.map((m, i) => (
    <a
      href={`/agences/${m.slug}/`}
      class:list={['cmap-marker', { 'is-main': m.principal }]}
      style={`--i:${i};`}
      aria-label={`${m.societe} — voir la page agence`}
    >
      <title>{m.societe}</title>

      {m.leader && (
        <line x1={m.x} y1={m.y} x2={m.leader.x} y2={m.leader.y} stroke="#1A190F" stroke-width="0.8" stroke-linecap="round" opacity="0.45" />
      )}

      {m.principal && (
        <>
          <circle cx={m.x} cy={m.y} r="22" fill="#2C6126" opacity="0.18" class="cmap-halo" />
          <circle cx={m.x} cy={m.y} r="14" fill="#2C6126" opacity="0.35" class="cmap-halo cmap-halo--inner" />
        </>
      )}

      {/* Zone de clic élargie (invisible) */}
      <circle cx={m.x} cy={m.y} r="16" fill="transparent" />

      <circle cx={m.x} cy={m.y + 1.5} r={m.principal ? 8.5 : 5.5} fill="rgba(0,0,0,0.25)" />
      <circle
        cx={m.x}
        cy={m.y}
        r={m.principal ? 8.5 : 5}
        fill={m.principal ? '#2C6126' : '#1A190F'}
        stroke="#fff"
        stroke-width={m.principal ? 2.4 : 1.8}
        class="cmap-dot"
      />
      {m.principal && <circle cx={m.x} cy={m.y} r="2" fill="#E4E13C" />}

      <text
        x={m.lx}
        y={m.ly}
        text-anchor={m.anchor}
        font-family="'Space Grotesk', sans-serif"
        font-size={m.principal ? 14 : 11.5}
        font-weight={m.principal ? 700 : 600}
        fill="#1A190F"
        class="cmap-label"
      >{m.name}</text>

      {/* Info-bulle au survol */}
      <g class="cmap-tip" transform={`translate(${m.x}, ${m.y - 16})`} aria-hidden="true">
        <rect x="-66" y="-34" width="132" height="30" rx="7" fill="#1A190F" />
        <path d="M-6,-4 L0,3 L6,-4 Z" fill="#1A190F" />
        <text x="0" y="-15" text-anchor="middle" font-family="'Space Grotesk', sans-serif" font-size="11" font-weight="700" fill="#E4E13C">Voir l'agence →</text>
      </g>
    </a>
  ))}
</svg>

<style>
  .cmap {
    width: 100%;
    height: 100%;
    display: block;
  }
  .cmap-region {
    fill: rgba(26,25,15,0.13);
    pointer-events: none;
    user-select: none;
  }

  /* Marqueur = lien */
  .cmap-marker {
    cursor: pointer;
    opacity: 0;
    animation: cmap-pin-in 0.5s var(--ease-out) forwards;
    animation-delay: calc(0.2s + var(--i) * 0.05s);
  }
  @keyframes cmap-pin-in {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .cmap-dot {
    transition: transform 0.2s var(--ease-standard);
    transform-box: fill-box;
    transform-origin: center;
  }
  .cmap-marker:hover .cmap-dot,
  .cmap-marker:focus-visible .cmap-dot {
    transform: scale(1.25);
  }

  .cmap-label {
    paint-order: stroke fill;
    stroke: rgba(251,246,208,0.85);
    stroke-width: 3.5;
    stroke-linejoin: round;
    transition: fill 0.2s var(--ease-standard);
  }
  .cmap-marker:hover .cmap-label,
  .cmap-marker:focus-visible .cmap-label {
    fill: #2C6126;
  }

  .cmap-halo {
    transform-origin: center;
    transform-box: fill-box;
    animation: cmap-halo-pulse 2.6s ease-in-out infinite;
  }
  .cmap-halo--inner { animation-delay: 0.3s; }
  @keyframes cmap-halo-pulse {
    0%, 100% { transform: scale(1);    opacity: 0.55; }
    50%      { transform: scale(1.45); opacity: 0.15; }
  }

  /* Info-bulle */
  .cmap-tip {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s var(--ease-standard);
  }
  .cmap-marker:hover .cmap-tip,
  .cmap-marker:focus-visible .cmap-tip {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .cmap-marker { animation: none; opacity: 1; transform: none; }
    .cmap-halo { animation: none; }
    .cmap-dot, .cmap-label, .cmap-tip { transition: none; }
  }
</style>
