---
// Bloc placeholder « contenu à rédiger ». Volontairement très visible
// dans le rendu pour repérer d'un coup d'œil ce qui reste à produire
// en Phase 2 (rédaction marketing, FAQ, intros locales, tarifs…).
//
// Usage :
//   <Todo titre="Intro locale Pérols">
//     2-3 paragraphes présentant l'agence de Pérols…
//   </Todo>

interface Props {
  /** Intitulé court de ce qui doit être produit. */
  titre: string;
  /** Étiquette de phase (par défaut « Phase 2 — contenu »). */
  phase?: string;
}

const { titre, phase = 'Phase 2 — contenu' } = Astro.props;
---

<div class="todo" role="note" aria-label={`À rédiger : ${titre}`}>
  <div class="todo-head">
    <span class="todo-badge mono">TODO</span>
    <span class="todo-titre">{titre}</span>
    <span class="todo-phase mono">{phase}</span>
  </div>
  <div class="todo-body">
    <slot>Contenu rédactionnel à produire en Phase 2.</slot>
  </div>
</div>

<style>
  .todo {
    border: 2px dashed var(--md-signal-400);
    background:
      repeating-linear-gradient(
        45deg,
        rgba(228, 225, 60, 0.07) 0,
        rgba(228, 225, 60, 0.07) 12px,
        transparent 12px,
        transparent 24px
      ),
      var(--md-signal-50);
    border-radius: var(--radius-lg);
    padding: 16px 18px;
  }
  .todo-head {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 8px;
  }
  .todo-badge {
    background: var(--md-brand-black);
    color: var(--md-brand-yellow);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    padding: 3px 8px;
    border-radius: var(--radius-xs);
  }
  .todo-titre {
    font-size: 13px;
    font-weight: 700;
    color: var(--md-stone-900);
  }
  .todo-phase {
    margin-left: auto;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--md-signal-600);
    text-transform: uppercase;
  }
  .todo-body {
    font-size: 13px;
    line-height: 1.6;
    color: var(--md-stone-600);
  }
  .todo-body :global(p) { margin: 0 0 8px; }
  .todo-body :global(p:last-child) { margin-bottom: 0; }
  .todo-body :global(ul) {
    margin: 0;
    padding-left: 18px;
    list-style: disc;
  }
  .todo-body :global(li) { margin-bottom: 4px; }
</style>
