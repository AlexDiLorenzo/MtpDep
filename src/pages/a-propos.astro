---
import BaseLayout from '../layouts/BaseLayout.astro';
import TopNav from '../components/TopNav.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import PageHero from '../components/PageHero.astro';
import ContentSection from '../components/ContentSection.astro';
import { organizationSchema, breadcrumbSchema } from '../lib/schema';

const pageTitle = 'À propos · Montpellier Dépannage — entreprise familiale de dépannage';
const pageDescription =
  "Montpellier Dépannage, entreprise familiale de remorquage et dépannage. Plus de 30 ans d'expérience, 8 agences et 40 dépanneurs certifiés dans l'Hérault et le Gard.";

const jsonLd = [
  organizationSchema(),
  breadcrumbSchema([
    { name: 'Accueil', url: '/' },
    { name: 'À propos', url: '/a-propos/' },
  ]),
];
---

<BaseLayout title={pageTitle} description={pageDescription} jsonLd={jsonLd}>
  <TopNav />
  <Breadcrumbs items={[{ name: 'Accueil', href: '/' }, { name: 'À propos' }]} />

  <main id="main">
    <PageHero
      overline="L'entreprise"
      title="Montpellier Dépannage, une histoire de famille."
      lead="Une entreprise familiale, devenue un réseau de 8 agences au service de l'Hérault et du Gard."
    />

    <ContentSection overline="Notre histoire" titre="Plus de 30 ans sur la route.">
      <p>
        Montpellier Dépannage est une entreprise familiale, construite génération
        après génération autour d'un métier exigeant&nbsp;: venir en aide, à toute
        heure, à celles et ceux dont le véhicule est immobilisé. En plus de
        30&nbsp;ans, elle est restée fidèle à son ancrage local et à ses valeurs.
      </p>
      <p>
        Au fil des années, l'activité s'est élargie&nbsp;: du dépannage de proximité
        aux interventions sur l'autoroute&nbsp;A9, du remorquage de voitures à celui
        des poids lourds, jusqu'au transport international de véhicules. Pour suivre
        la croissance de l'agglomération et couvrir tout l'Hérault et le Gard,
        l'entreprise est devenue un réseau de 8&nbsp;agences.
      </p>
      <p>
        Ce qui n'a pas changé&nbsp;: une entreprise dirigée en famille, des
        dépanneurs formés et fidèles, et la conviction qu'un véhicule immobilisé est
        d'abord une personne qui a besoin d'aide.
      </p>
    </ContentSection>

    <ContentSection overline="Nos valeurs" titre="Ce qui nous engage." alt>
      <p>
        <strong>Disponibilité totale.</strong> Une astreinte réelle, 24&nbsp;h/24
        et 7&nbsp;j/7, jours fériés compris. Quand vous appelez, un dépanneur
        décroche et se met en route&nbsp;: c'est le cœur de notre métier.
      </p>
      <p>
        <strong>Sécurité et savoir-faire.</strong> Nos équipes sont certifiées
        NF&nbsp;Service et formées aux interventions les plus exigeantes&nbsp;:
        autoroute, poids lourds, véhicules de prestige, zones piétonnes. Chaque
        véhicule est pris en charge avec le matériel adapté.
      </p>
      <p>
        <strong>Transparence.</strong> Un devis clair avant l'intervention, aucune
        mauvaise surprise, et la possibilité d'une prise en charge directe par votre
        assistance, sans avance de frais.
      </p>
      <p>
        <strong>Respect du territoire.</strong> Une flotte électrique pour le cœur
        historique de Montpellier et une démarche environnementale reconnue par le
        label Envol&nbsp;: dépanner mieux, sans dégrader la ville.
      </p>
    </ContentSection>

    <ContentSection overline="Le réseau" titre="8 agences, 40 dépanneurs.">
      <p>
        Le réseau Montpellier Dépannage s'appuie sur 8&nbsp;agences réparties dans
        l'Hérault et le Gard, avec une présence permanente sur l'autoroute&nbsp;A9.
        <a href="/agences/">Découvrir les agences →</a>
      </p>
    </ContentSection>
  </main>

  <Footer />
</BaseLayout>
